# Environment
NODE_ENV=development
PORT=3000

# Session Configuration
SESSION_SECRET=change_me_to_a_long_random_string_minimum_32_characters

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cbt_smk

# Redis Configuration (OPTIONAL - for Session Store)
# Jika tidak diset atau REDIS_HOST=localhost, akan menggunakan memory store
# Memory store: Session tersimpan di RAM server (hilang saat restart)
# Redis store: Session persistent, cocok untuk production

# Uncomment baris di bawah untuk menggunakan Redis:
# REDIS_HOST=redis.yourdomain.com
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password

# Atau untuk Redis lokal:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
