<main class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-8">
    <!-- Flash Messages -->
    <% if (flash.success && flash.success.length > 0) { %>
      <div class="mb-6 rounded-xl border-2 border-emerald-200 bg-emerald-50 px-4 py-3 text-emerald-800">
        <%= flash.success[0] %>
      </div>
    <% } %>
    <% if (flash.error && flash.error.length > 0) { %>
      <div class="mb-6 rounded-xl border-2 border-rose-200 bg-rose-50 px-4 py-3 text-rose-800">
        <%= flash.error[0] %>
      </div>
    <% } %>

    <!-- Profile Header -->
    <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-green-50 to-green-100 border-2 border-green-200 shadow-lg mb-6">
      <div class="absolute inset-0 opacity-30">
        <div class="absolute top-0 right-0 w-64 h-64 bg-white rounded-full -mr-32 -mt-32"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-white rounded-full -ml-24 -mb-24"></div>
        <div class="absolute top-1/2 left-1/2 w-32 h-32 bg-green-200 rounded-full -ml-16 -mt-16"></div>
      </div>
      <div class="relative px-6 py-8">
        <div class="flex items-center gap-4">
          <div class="bg-white/60 backdrop-blur-sm rounded-2xl p-2 shadow-md border-2 border-green-200">
            <% if (user.profile_photo) { %>
              <img src="<%= user.profile_photo %>" alt="Profile Photo" class="w-20 h-20 rounded-xl object-cover">
            <% } else { %>
              <div class="w-20 h-20 rounded-xl bg-gradient-to-br from-green-100 to-green-200 flex items-center justify-center">
                <svg class="w-12 h-12 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
            <% } %>
          </div>
          <div>
            <h1 class="text-3xl font-bold text-green-800 tracking-tight flex items-center gap-2">
              <span>Profil Saya</span>
              <span class="text-2xl">✨</span>
            </h1>
            <p class="mt-1 text-green-700 font-medium">Kelola informasi profil dan foto Anda 📸</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Profile Content -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Profile Photo Card -->
      <div class="lg:col-span-1">
        <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-2xl shadow-lg border-2 border-blue-200 p-6">
          <h2 class="text-lg font-bold text-blue-800 mb-4 flex items-center gap-2">
            <span>📷</span>
            <span>Foto Profil</span>
          </h2>
          
          <div class="flex flex-col items-center">
            <div class="relative mb-4">
              <% if (profileUser.profile_photo) { %>
                <img src="<%= profileUser.profile_photo %>" alt="Profile Photo" class="w-40 h-40 rounded-full object-cover border-4 border-indigo-200 shadow-lg" id="profilePreview">
              <% } else { %>
                <div class="w-40 h-40 rounded-full bg-gradient-to-br from-indigo-100 to-purple-100 border-4 border-indigo-200 shadow-lg flex items-center justify-center" id="profilePreview">
                  <svg class="w-20 h-20 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                </div>
              <% } %>
            </div>
            
            <div class="text-center mb-4">
              <div class="font-semibold text-blue-900"><%= profileUser.full_name %></div>
              <div class="text-sm text-blue-700"><%= profileUser.role %></div>
              <% if (profileUser.class_name) { %>
                <div class="text-sm text-blue-600"><%= profileUser.class_name %></div>
              <% } %>
            </div>

            <form action="/profile/update" method="POST" enctype="multipart/form-data" id="photoForm" class="w-full">
              <input type="hidden" name="full_name" value="<%= profileUser.full_name %>">
              
              <label for="profile_photo" class="block w-full cursor-pointer">
                <div class="px-4 py-2 bg-gradient-to-r from-indigo-500 to-purple-600 hover:from-indigo-600 hover:to-purple-700 text-white font-semibold rounded-xl text-center transition-all shadow-md hover:shadow-lg transform hover:scale-105">
                  Pilih Foto
                </div>
                <input type="file" id="profile_photo" name="profile_photo" accept="image/*" class="hidden">
              </label>
              
              <div id="photoInfo" class="hidden mt-3 text-sm text-blue-700 text-center">
                <div id="photoName" class="font-medium"></div>
                <div id="photoSize" class="text-xs text-blue-600"></div>
                <button type="submit" class="mt-2 w-full px-4 py-2 bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-600 hover:to-teal-700 text-white font-semibold rounded-xl transition-all shadow-md hover:shadow-lg transform hover:scale-105">
                  Upload Foto
                </button>
              </div>
            </form>

            <% if (profileUser.profile_photo) { %>
              <form action="/profile/delete-photo" method="POST" class="w-full mt-3" onsubmit="return confirm('Yakin ingin menghapus foto profil?')">
                <button type="submit" class="w-full px-4 py-2 bg-gradient-to-r from-rose-500 to-red-600 hover:from-rose-600 hover:to-red-700 text-white font-semibold rounded-xl transition-all shadow-md hover:shadow-lg transform hover:scale-105">
                  Hapus Foto
                </button>
              </form>
            <% } %>

            <div class="mt-4 text-xs text-blue-600 text-center">
              <p>Format: JPG, PNG, GIF, WebP</p>
              <p>Maksimal: 5MB</p>
              <p>Foto akan dikompres otomatis</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Profile Info Card -->
      <div class="lg:col-span-2">
        <div class="bg-gradient-to-br from-purple-50 to-purple-100 rounded-2xl shadow-lg border-2 border-purple-200 p-6">
          <h2 class="text-lg font-bold text-purple-800 mb-4 flex items-center gap-2">
            <span>📝</span>
            <span>Informasi Profil</span>
          </h2>
          
          <form action="/profile/update" method="POST" class="space-y-4">
            <div>
              <label class="block text-sm font-semibold text-purple-700 mb-2">Username</label>
              <input type="text" value="<%= profileUser.username %>" disabled class="w-full px-4 py-2.5 border-2 border-purple-200 rounded-xl bg-purple-50 text-purple-600 cursor-not-allowed">
              <p class="mt-1 text-xs text-purple-600">Username tidak dapat diubah</p>
            </div>

            <div>
              <label class="block text-sm font-semibold text-purple-700 mb-2">Nama Lengkap</label>
              <input type="text" name="full_name" value="<%= profileUser.full_name %>" required class="w-full px-4 py-2.5 border-2 border-purple-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition-all bg-white">
            </div>

            <div>
              <label class="block text-sm font-semibold text-purple-700 mb-2">Role</label>
              <input type="text" value="<%= profileUser.role %>" disabled class="w-full px-4 py-2.5 border-2 border-purple-200 rounded-xl bg-purple-50 text-purple-600 cursor-not-allowed">
            </div>

            <% if (profileUser.class_name) { %>
              <div>
                <label class="block text-sm font-semibold text-purple-700 mb-2">Kelas</label>
                <input type="text" value="<%= profileUser.class_name %>" disabled class="w-full px-4 py-2.5 border-2 border-purple-200 rounded-xl bg-purple-50 text-purple-600 cursor-not-allowed">
              </div>
            <% } %>

            <div class="border-t-2 border-purple-200 pt-4 mt-6">
              <h3 class="text-md font-bold text-purple-800 mb-4 flex items-center gap-2">
                <span>🔐</span>
                <span>Ubah Password</span>
              </h3>
              <p class="text-sm text-purple-700 mb-4">Kosongkan jika tidak ingin mengubah password</p>
              
              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-semibold text-purple-700 mb-2">Password Baru</label>
                  <input type="password" name="new_password" placeholder="Minimal 6 karakter" class="w-full px-4 py-2.5 border-2 border-purple-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition-all bg-white">
                </div>

                <div>
                  <label class="block text-sm font-semibold text-purple-700 mb-2">Konfirmasi Password Baru</label>
                  <input type="password" name="confirm_password" placeholder="Ulangi password baru" class="w-full px-4 py-2.5 border-2 border-purple-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition-all bg-white">
                </div>
              </div>
            </div>

            <div class="flex gap-3 pt-4">
              <button type="submit" class="flex-1 px-6 py-3 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white font-semibold rounded-xl shadow-lg transform hover:scale-105 transition-all duration-200">
                Simpan Perubahan
              </button>
              <a href="/dashboard" class="px-6 py-3 bg-gradient-to-r from-slate-200 to-slate-300 hover:from-slate-300 hover:to-slate-400 text-slate-700 font-semibold rounded-xl shadow-md transform hover:scale-105 transition-all duration-200 text-center">
                Batal
              </a>
            </div>
          </form>
        </div>

        <!-- Account Info Card -->
        <div class="bg-gradient-to-br from-green-50 to-green-100 rounded-2xl shadow-lg border-2 border-green-200 p-6 mt-6">
          <h2 class="text-lg font-bold text-green-800 mb-4 flex items-center gap-2">
            <span>ℹ️</span>
            <span>Informasi Akun</span>
          </h2>
          
          <div class="space-y-3">
            <div class="flex justify-between items-center py-2 border-b border-green-200">
              <span class="text-sm text-green-700">Status Akun</span>
              <span class="px-3 py-1 rounded-full text-xs font-bold <%= profileUser.is_active ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                <%= profileUser.is_active ? 'Aktif' : 'Nonaktif' %>
              </span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-green-200">
              <span class="text-sm text-green-700">Terdaftar Sejak</span>
              <span class="text-sm font-medium text-green-900">
                <%= new Date(profileUser.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

<script>
  // Photo preview and upload handling
  const photoInput = document.getElementById('profile_photo');
  const photoPreview = document.getElementById('profilePreview');
  const photoInfo = document.getElementById('photoInfo');
  const photoName = document.getElementById('photoName');
  const photoSize = document.getElementById('photoSize');

  photoInput.addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (file) {
      // Show file info
      photoName.textContent = file.name;
      photoSize.textContent = `Ukuran: ${(file.size / 1024).toFixed(2)} KB`;
      photoInfo.classList.remove('hidden');

      // Preview image
      const reader = new FileReader();
      reader.onload = function(e) {
        if (photoPreview.tagName === 'IMG') {
          photoPreview.src = e.target.result;
        } else {
          const img = document.createElement('img');
          img.src = e.target.result;
          img.className = 'w-40 h-40 rounded-full object-cover border-4 border-indigo-200 shadow-lg';
          photoPreview.replaceWith(img);
          img.id = 'profilePreview';
        }
      };
      reader.readAsDataURL(file);
    }
  });
</script>
