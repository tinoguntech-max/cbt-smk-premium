<div class="flex items-center justify-between gap-4 mb-6">
  <div>
    <h1 class="text-3xl font-bold text-pink-900">Manajemen Bank Soal</h1>
    <p class="text-sm text-slate-600 mt-1">Kelola semua bank soal dari guru</p>
  </div>
  <a href="/admin" class="text-sm px-4 py-2 rounded-xl border border-slate-200 bg-gradient-to-br from-slate-50 to-slate-100 hover:from-slate-100 hover:to-slate-200 text-slate-800 font-medium transition-all">
    Kembali
  </a>
</div>

<!-- Filter -->
<div class="rounded-2xl border border-pink-200 bg-gradient-to-br from-pink-50 to-pink-100 p-4 mb-6 shadow-soft">
  <form method="GET" action="/admin/question-bank" class="flex flex-wrap gap-3">
    <input 
      type="text" 
      name="search" 
      value="<%= search || '' %>" 
      placeholder="Cari soal atau nama guru..." 
      class="flex-1 min-w-[200px] rounded-xl border border-pink-200 bg-white px-4 py-2 focus:outline-none focus:ring-2 focus:ring-pink-500"
    />
    <select 
      name="subject_id" 
      class="rounded-xl border border-pink-200 bg-white px-4 py-2 focus:outline-none focus:ring-2 focus:ring-pink-500"
    >
      <option value="">Semua Mata Pelajaran</option>
      <% subjects.forEach(s => { %>
        <option value="<%= s.id %>" <%= subject_id == s.id ? 'selected' : '' %>><%= s.name %></option>
      <% }) %>
    </select>
    <select 
      name="difficulty" 
      class="rounded-xl border border-pink-200 bg-white px-4 py-2 focus:outline-none focus:ring-2 focus:ring-pink-500"
    >
      <option value="">Semua Tingkat</option>
      <option value="EASY" <%= difficulty === 'EASY' ? 'selected' : '' %>>Mudah</option>
      <option value="MEDIUM" <%= difficulty === 'MEDIUM' ? 'selected' : '' %>>Sedang</option>
      <option value="HARD" <%= difficulty === 'HARD' ? 'selected' : '' %>>Sulit</option>
    </select>
    <button type="submit" class="px-6 py-2 rounded-xl bg-gradient-to-r from-pink-500 to-rose-600 hover:from-pink-600 hover:to-rose-700 text-white font-semibold shadow-lg transition-all">
      Filter
    </button>
    <% if (search || subject_id || difficulty) { %>
      <a href="/admin/question-bank" class="px-6 py-2 rounded-xl border border-pink-300 hover:bg-pink-50 text-pink-700 font-semibold transition-all">
        Reset
      </a>
    <% } %>
  </form>
</div>

<!-- Stats -->
<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <div class="rounded-2xl border border-pink-200 bg-gradient-to-br from-pink-50 to-pink-100 p-4 shadow-soft">
    <div class="text-sm text-pink-600 font-medium">Total Soal</div>
    <div class="mt-1 text-2xl font-bold text-pink-900"><%= stats.total %></div>
  </div>
  <div class="rounded-2xl border border-green-200 bg-gradient-to-br from-green-50 to-green-100 p-4 shadow-soft">
    <div class="text-sm text-green-600 font-medium">Mudah</div>
    <div class="mt-1 text-2xl font-bold text-green-900"><%= stats.easy %></div>
  </div>
  <div class="rounded-2xl border border-amber-200 bg-gradient-to-br from-amber-50 to-amber-100 p-4 shadow-soft">
    <div class="text-sm text-amber-600 font-medium">Sedang</div>
    <div class="mt-1 text-2xl font-bold text-amber-900"><%= stats.medium %></div>
  </div>
  <div class="rounded-2xl border border-red-200 bg-gradient-to-br from-red-50 to-red-100 p-4 shadow-soft">
    <div class="text-sm text-red-600 font-medium">Sulit</div>
    <div class="mt-1 text-2xl font-bold text-red-900"><%= stats.hard %></div>
  </div>
</div>

<!-- Table -->
<div class="rounded-2xl border border-pink-200 bg-white shadow-soft overflow-hidden">
  <!-- Bulk Actions -->
  <div id="bulkActions" class="hidden bg-gradient-to-r from-pink-100 to-rose-100 border-b border-pink-200 px-4 py-3">
    <div class="flex items-center justify-between">
      <span class="text-sm font-semibold text-pink-900">
        <span id="selectedCount">0</span> soal dipilih
      </span>
      <button 
        type="button" 
        onclick="bulkDelete()" 
        class="px-4 py-2 rounded-lg bg-gradient-to-r from-red-500 to-red-600 hover:from-red-600 hover:to-red-700 text-white text-sm font-semibold transition-all"
      >
        Hapus Terpilih
      </button>
    </div>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full">
      <thead class="bg-gradient-to-r from-pink-50 to-rose-50 border-b border-pink-200">
        <tr>
          <th class="px-4 py-3 text-center">
            <input 
              type="checkbox" 
              id="selectAll" 
              class="w-4 h-4 accent-pink-500 cursor-pointer"
              onchange="toggleSelectAll(this)"
            />
          </th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-pink-900 uppercase">Soal</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-pink-900 uppercase">Guru</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-pink-900 uppercase">Mata Pelajaran</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-pink-900 uppercase">Tingkat</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-pink-900 uppercase">Tags</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-pink-900 uppercase">Dibuat</th>
          <th class="px-4 py-3 text-center text-xs font-semibold text-pink-900 uppercase">Aksi</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-pink-100">
        <% if (questions.length === 0) { %>
          <tr>
            <td colspan="8" class="px-4 py-8 text-center text-slate-500">
              Tidak ada soal ditemukan
            </td>
          </tr>
        <% } else { %>
          <% questions.forEach(q => { %>
            <tr class="hover:bg-pink-50 transition-colors">
              <td class="px-4 py-3 text-center">
                <input 
                  type="checkbox" 
                  class="question-checkbox w-4 h-4 accent-pink-500 cursor-pointer" 
                  value="<%= q.id %>"
                  onchange="updateBulkActions()"
                />
              </td>
              <td class="px-4 py-3">
                <div class="text-sm text-slate-900 line-clamp-2">
                  <%= q.question_text.substring(0, 100) %><%= q.question_text.length > 100 ? '...' : '' %>
                </div>
                <% if (q.question_image) { %>
                  <span class="inline-flex items-center mt-1 px-2 py-0.5 rounded text-xs font-semibold bg-blue-100 text-blue-800">
                    📷 Gambar
                  </span>
                <% } %>
                <% if (q.question_pdf) { %>
                  <span class="inline-flex items-center mt-1 px-2 py-0.5 rounded text-xs font-semibold bg-red-100 text-red-800">
                    📄 PDF
                  </span>
                <% } %>
              </td>
              <td class="px-4 py-3 text-sm text-slate-700"><%= q.teacher_name %></td>
              <td class="px-4 py-3 text-sm text-slate-700"><%= q.subject_name %></td>
              <td class="px-4 py-3">
                <% if (q.difficulty === 'EASY') { %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-800">
                    Mudah
                  </span>
                <% } else if (q.difficulty === 'MEDIUM') { %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-amber-100 text-amber-800">
                    Sedang
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-red-100 text-red-800">
                    Sulit
                  </span>
                <% } %>
              </td>
              <td class="px-4 py-3">
                <% if (q.tags) { %>
                  <div class="flex flex-wrap gap-1">
                    <% q.tags.split(',').slice(0, 2).forEach(tag => { %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-slate-100 text-slate-700">
                        <%= tag.trim() %>
                      </span>
                    <% }) %>
                    <% if (q.tags.split(',').length > 2) { %>
                      <span class="text-xs text-slate-500">+<%= q.tags.split(',').length - 2 %></span>
                    <% } %>
                  </div>
                <% } else { %>
                  <span class="text-slate-400 text-sm">-</span>
                <% } %>
              </td>
              <td class="px-4 py-3 text-sm text-slate-700">
                <%= new Date(q.created_at).toLocaleDateString('id-ID') %>
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center justify-center gap-2">
                  <a href="/admin/question-bank/<%= q.id %>" class="px-3 py-1.5 rounded-lg bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white text-xs font-semibold transition-all">
                    Detail
                  </a>
                  <form method="POST" action="/admin/question-bank/<%= q.id %>/delete" onsubmit="return confirm('Yakin ingin menghapus soal ini?');" class="inline">
                    <button type="submit" class="px-3 py-1.5 rounded-lg bg-gradient-to-r from-red-500 to-red-600 hover:from-red-600 hover:to-red-700 text-white text-xs font-semibold transition-all">
                      Hapus
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<script>
  function toggleSelectAll(checkbox) {
    const checkboxes = document.querySelectorAll('.question-checkbox');
    checkboxes.forEach(cb => cb.checked = checkbox.checked);
    updateBulkActions();
  }

  function updateBulkActions() {
    const checkboxes = document.querySelectorAll('.question-checkbox:checked');
    const count = checkboxes.length;
    const bulkActions = document.getElementById('bulkActions');
    const selectedCount = document.getElementById('selectedCount');
    const selectAll = document.getElementById('selectAll');

    selectedCount.textContent = count;
    
    if (count > 0) {
      bulkActions.classList.remove('hidden');
    } else {
      bulkActions.classList.add('hidden');
    }

    // Update select all checkbox
    const allCheckboxes = document.querySelectorAll('.question-checkbox');
    selectAll.checked = allCheckboxes.length > 0 && count === allCheckboxes.length;
  }

  function bulkDelete() {
    const checkboxes = document.querySelectorAll('.question-checkbox:checked');
    const ids = Array.from(checkboxes).map(cb => cb.value);
    
    if (ids.length === 0) {
      alert('Pilih minimal 1 soal untuk dihapus');
      return;
    }

    if (!confirm(`Yakin ingin menghapus ${ids.length} soal terpilih?`)) {
      return;
    }

    // Create form and submit
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '/admin/question-bank/bulk-delete';
    
    ids.forEach(id => {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'ids[]';
      input.value = id;
      form.appendChild(input);
    });
    
    document.body.appendChild(form);
    form.submit();
  }
</script>
