<div class="flex items-center justify-between gap-4 mb-6">
  <div>
    <h1 class="text-3xl font-bold text-indigo-900">Detail Tugas</h1>
    <p class="mt-1 text-slate-600">Informasi lengkap tugas dan pengumpulan siswa</p>
  </div>
  <a href="/admin/assignments" class="px-4 py-2 rounded-xl border border-rose-200 bg-gradient-to-br from-rose-50 to-pink-100 hover:from-rose-100 hover:to-pink-200 text-rose-800 font-medium transition-all">
    ← Kembali
  </a>
</div>

<!-- Assignment Info -->
<div class="rounded-2xl border-2 border-indigo-200 bg-gradient-to-br from-indigo-50 to-purple-50 p-6 mb-6">
  <div class="grid md:grid-cols-2 gap-6">
    <div>
      <h2 class="text-2xl font-bold text-indigo-900 mb-4"><%= assignment.title %></h2>
      <div class="space-y-3">
        <div class="flex items-center gap-2">
          <span class="text-sm font-medium text-slate-600">Guru:</span>
          <span class="text-sm text-slate-900"><%= assignment.teacher_name %></span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-sm font-medium text-slate-600">Mata Pelajaran:</span>
          <span class="inline-flex items-center px-3 py-1 rounded-lg text-sm font-semibold bg-purple-100 text-purple-800">
            <%= assignment.subject_name %>
          </span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-sm font-medium text-slate-600">Kelas:</span>
          <span class="inline-flex items-center px-3 py-1 rounded-lg text-sm font-semibold bg-cyan-100 text-cyan-800">
            <%= assignment.class_name || 'Semua Kelas' %>
          </span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-sm font-medium text-slate-600">Status:</span>
          <% if (assignment.is_published) { %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-green-100 text-green-700">
              Dipublikasi
            </span>
          <% } else { %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-orange-100 text-orange-700">
              Draft
            </span>
          <% } %>
        </div>
      </div>
    </div>
    
    <div>
      <h3 class="text-lg font-semibold text-indigo-900 mb-3">Deskripsi</h3>
      <div class="prose prose-sm max-w-none text-slate-700">
        <%- assignment.description || '<em>Tidak ada deskripsi</em>' %>
      </div>
      
      <% if (assignment.attachment_url) { %>
        <div class="mt-4">
          <a href="<%= assignment.attachment_url %>" target="_blank" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-blue-100 hover:bg-blue-200 text-blue-800 font-medium transition-all">
            📎 Lihat Lampiran
          </a>
        </div>
      <% } %>
      
      <div class="mt-4 grid grid-cols-2 gap-3 text-sm">
        <div class="bg-white rounded-xl p-3">
          <div class="text-slate-600">Deadline</div>
          <div class="font-semibold text-slate-900">
            <%= assignment.due_date ? new Date(assignment.due_date).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : '-' %>
          </div>
        </div>
        <div class="bg-white rounded-xl p-3">
          <div class="text-slate-600">Dibuat</div>
          <div class="font-semibold text-slate-900">
            <%= new Date(assignment.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Stats -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
  <div class="rounded-2xl border-2 border-blue-200 bg-gradient-to-br from-blue-50 to-cyan-50 p-5">
    <div class="text-sm text-blue-700 font-medium">Total Pengumpulan</div>
    <div class="mt-2 text-3xl font-bold text-blue-900"><%= stats.total_submissions %></div>
  </div>
  <div class="rounded-2xl border-2 border-green-200 bg-gradient-to-br from-green-50 to-emerald-50 p-5">
    <div class="text-sm text-green-700 font-medium">Sudah Dinilai</div>
    <div class="mt-2 text-3xl font-bold text-green-900"><%= stats.graded %></div>
  </div>
  <div class="rounded-2xl border-2 border-orange-200 bg-gradient-to-br from-orange-50 to-amber-50 p-5">
    <div class="text-sm text-orange-700 font-medium">Belum Dinilai</div>
    <div class="mt-2 text-3xl font-bold text-orange-900"><%= stats.pending %></div>
  </div>
  <div class="rounded-2xl border-2 border-purple-200 bg-gradient-to-br from-purple-50 to-pink-50 p-5">
    <div class="text-sm text-purple-700 font-medium">Rata-rata Nilai</div>
    <div class="mt-2 text-3xl font-bold text-purple-900"><%= stats.avg_score.toFixed(1) %></div>
  </div>
</div>

<!-- Submissions List -->
<div class="rounded-2xl border-2 border-slate-200 bg-white overflow-hidden">
  <div class="bg-gradient-to-r from-slate-50 to-slate-100 px-6 py-4 border-b-2 border-slate-200">
    <h2 class="text-lg font-bold text-slate-800">Daftar Pengumpulan</h2>
  </div>
  
  <% if (submissions.length === 0) { %>
    <div class="p-12 text-center">
      <div class="text-6xl mb-3">📝</div>
      <div class="font-semibold text-slate-900 text-lg">Belum ada pengumpulan</div>
      <div class="text-sm text-slate-600 mt-1">Siswa belum mengumpulkan tugas ini</div>
    </div>
  <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gradient-to-r from-indigo-50 to-purple-50 border-b-2 border-indigo-100">
          <tr>
            <th class="px-4 py-4 text-left text-xs font-bold text-indigo-900 uppercase">Siswa</th>
            <th class="px-4 py-4 text-left text-xs font-bold text-purple-900 uppercase">Kelas</th>
            <th class="px-4 py-4 text-left text-xs font-bold text-cyan-900 uppercase">Waktu Pengumpulan</th>
            <th class="px-4 py-4 text-left text-xs font-bold text-green-900 uppercase">Nilai</th>
            <th class="px-4 py-4 text-left text-xs font-bold text-blue-900 uppercase">Aksi</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% submissions.forEach((sub, index) => { %>
            <tr class="hover:bg-gradient-to-r hover:from-indigo-50 hover:to-purple-50 transition-all <%= index % 2 === 0 ? 'bg-white' : 'bg-slate-50' %>">
              <td class="px-4 py-4">
                <div class="font-semibold text-slate-900"><%= sub.student_name %></div>
                <div class="text-sm text-slate-600"><%= sub.student_username %></div>
              </td>
              <td class="px-4 py-4">
                <span class="inline-flex items-center px-3 py-1 rounded-lg text-sm font-semibold bg-cyan-100 text-cyan-800">
                  <%= sub.class_name || '-' %>
                </span>
              </td>
              <td class="px-4 py-4">
                <div class="text-sm text-slate-900">
                  <%= new Date(sub.submitted_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                </div>
                <div class="text-xs text-slate-600">
                  <%= new Date(sub.submitted_at).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %>
                </div>
              </td>
              <td class="px-4 py-4">
                <% if (sub.score !== null) { %>
                  <span class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-bold bg-green-100 text-green-800">
                    <%= sub.score %>
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-bold bg-orange-100 text-orange-800">
                    Belum Dinilai
                  </span>
                <% } %>
              </td>
              <td class="px-4 py-4">
                <% if (sub.file_url) { %>
                  <a href="<%= sub.file_url %>" target="_blank" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg bg-blue-100 hover:bg-blue-200 text-blue-800 text-sm font-medium transition-all">
                    📄 Lihat File
                  </a>
                <% } else { %>
                  <span class="text-sm text-slate-400">Tidak ada file</span>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
