<div class="flex items-center justify-between gap-4">
  <div>
    <div class="text-sm text-slate-500">Pengguna → Guru</div>
    <h1 class="text-3xl font-semibold tracking-tight">Preview Import Guru</h1>
    <p class="mt-1 text-slate-600">Periksa data valid & error sebelum commit.</p>
  </div>
  <div class="flex gap-2">
    <a href="/admin/teachers/import" class="px-4 py-2 rounded-xl border border-slate-200 hover:bg-slate-100">Upload Ulang</a>
    <a href="/admin/teachers" class="px-4 py-2 rounded-xl border border-slate-200 hover:bg-slate-100">Kembali</a>
  </div>
</div>

<div class="mt-6 grid lg:grid-cols-2 gap-4">
  <div class="rounded-2xl border border-slate-200 bg-slate-100 p-5">
    <div class="flex items-center justify-between">
      <div class="text-lg font-semibold">Data Valid</div>
      <div class="text-sm text-slate-600"><%= (preview || []).length %> baris</div>
    </div>

    <% if (!(preview || []).length) { %>
      <div class="mt-3 text-sm text-slate-600">Tidak ada baris valid.</div>
    <% } else { %>
      <div class="mt-4 overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="text-slate-500">
            <tr>
              <th class="text-left py-2">#</th>
              <th class="text-left py-2">Username</th>
              <th class="text-left py-2">Nama</th>
              <th class="text-left py-2">Pwd</th>
              <th class="text-left py-2">Aksi</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/10">
            <% preview.forEach(p => { %>
              <tr>
                <td class="py-2"><%= p.rowNo %></td>
                <td class="py-2 font-mono"><%= p.username %></td>
                <td class="py-2"><%= p.full_name %></td>
                <td class="py-2"><%= p.passwordProvided ? 'YA' : '-' %></td>
                <td class="py-2"><span class="px-2 py-1 rounded-lg border border-slate-200"><%= p.action %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <form action="/admin/teachers/import/commit" method="POST" class="mt-4">
        <input type="hidden" name="importId" value="<%= importId %>" />
        <button class="w-full rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white font-semibold py-3" onclick="return confirm('Commit import guru?')">Commit Import</button>
      </form>
    <% } %>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-slate-100 p-5">
    <div class="flex items-center justify-between">
      <div class="text-lg font-semibold">Error</div>
      <div class="text-sm text-slate-600"><%= (errors || []).length %> baris</div>
    </div>

    <% if ((errors || []).length) { %>
      <div class="mt-4 flex gap-2">
        <a href="/admin/teachers/import/errors.csv" class="px-4 py-2 rounded-xl border border-slate-200 hover:bg-slate-100 text-sm">Download Error CSV</a>
      </div>
    <% } %>

    <div class="mt-4 space-y-3">
      <% (errors || []).slice(0, 25).forEach(e => { %>
        <div class="rounded-xl border border-rose-500/20 bg-rose-500/10 p-4">
          <div class="text-sm font-semibold">Baris <%= e.rowNo %></div>
          <ul class="mt-2 text-xs text-slate-700 list-disc pl-5 space-y-1">
            <% (e.reasons || []).forEach(r => { %>
              <li><%= r %></li>
            <% }) %>
          </ul>
        </div>
      <% }) %>
      <% if ((errors || []).length > 25) { %>
        <div class="text-xs text-slate-500">Menampilkan 25 error pertama. Download CSV untuk semua.</div>
      <% } %>
    </div>
  </div>
</div>
