<div class="flex items-center justify-between gap-4 mb-6">
  <div>
    <h1 class="text-3xl font-bold text-amber-900">Manajemen Tugas</h1>
    <p class="text-sm text-slate-600 mt-1">Kelola semua tugas dari guru</p>
  </div>
  <a href="/admin" class="text-sm px-4 py-2 rounded-xl border border-slate-200 bg-gradient-to-br from-slate-50 to-slate-100 hover:from-slate-100 hover:to-slate-200 text-slate-800 font-medium transition-all">
    Kembali
  </a>
</div>

<!-- Filter -->
<div class="rounded-2xl border border-amber-200 bg-gradient-to-br from-amber-50 to-amber-100 p-4 mb-6 shadow-soft">
  <form method="GET" action="/admin/assignments" class="flex flex-wrap gap-3">
    <input 
      type="text" 
      name="search" 
      value="<%= search || '' %>" 
      placeholder="Cari judul tugas atau nama guru..." 
      class="flex-1 min-w-[200px] rounded-xl border border-amber-200 bg-white px-4 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500"
    />
    <select 
      name="subject_id" 
      class="rounded-xl border border-amber-200 bg-white px-4 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500"
    >
      <option value="">Semua Mata Pelajaran</option>
      <% subjects.forEach(s => { %>
        <option value="<%= s.id %>" <%= subject_id == s.id ? 'selected' : '' %>><%= s.name %></option>
      <% }) %>
    </select>
    <select 
      name="status" 
      class="rounded-xl border border-amber-200 bg-white px-4 py-2 focus:outline-none focus:ring-2 focus:ring-amber-500"
    >
      <option value="">Semua Status</option>
      <option value="published" <%= status === 'published' ? 'selected' : '' %>>Published</option>
      <option value="draft" <%= status === 'draft' ? 'selected' : '' %>>Draft</option>
    </select>
    <button type="submit" class="px-6 py-2 rounded-xl bg-gradient-to-r from-amber-500 to-orange-600 hover:from-amber-600 hover:to-orange-700 text-white font-semibold shadow-lg transition-all">
      Filter
    </button>
    <% if (search || subject_id || status) { %>
      <a href="/admin/assignments" class="px-6 py-2 rounded-xl border border-amber-300 hover:bg-amber-50 text-amber-700 font-semibold transition-all">
        Reset
      </a>
    <% } %>
  </form>
</div>

<!-- Stats -->
<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <div class="rounded-2xl border border-amber-200 bg-gradient-to-br from-amber-50 to-amber-100 p-4 shadow-soft">
    <div class="text-sm text-amber-600 font-medium">Total Tugas</div>
    <div class="mt-1 text-2xl font-bold text-amber-900"><%= stats.total %></div>
  </div>
  <div class="rounded-2xl border border-green-200 bg-gradient-to-br from-green-50 to-green-100 p-4 shadow-soft">
    <div class="text-sm text-green-600 font-medium">Published</div>
    <div class="mt-1 text-2xl font-bold text-green-900"><%= stats.published %></div>
  </div>
  <div class="rounded-2xl border border-slate-200 bg-gradient-to-br from-slate-50 to-slate-100 p-4 shadow-soft">
    <div class="text-sm text-slate-600 font-medium">Draft</div>
    <div class="mt-1 text-2xl font-bold text-slate-900"><%= stats.draft %></div>
  </div>
  <div class="rounded-2xl border border-blue-200 bg-gradient-to-br from-blue-50 to-blue-100 p-4 shadow-soft">
    <div class="text-sm text-blue-600 font-medium">Total Submission</div>
    <div class="mt-1 text-2xl font-bold text-blue-900"><%= stats.submissions %></div>
  </div>
</div>

<!-- Table -->
<div class="rounded-2xl border border-amber-200 bg-white shadow-soft overflow-hidden">
  <!-- Bulk Actions -->
  <div id="bulkActions" class="hidden bg-gradient-to-r from-amber-100 to-orange-100 border-b border-amber-200 px-4 py-3">
    <div class="flex items-center justify-between">
      <span class="text-sm font-semibold text-amber-900">
        <span id="selectedCount">0</span> tugas dipilih
      </span>
      <button 
        type="button" 
        onclick="bulkDelete()" 
        class="px-4 py-2 rounded-lg bg-gradient-to-r from-red-500 to-red-600 hover:from-red-600 hover:to-red-700 text-white text-sm font-semibold transition-all"
      >
        Hapus Terpilih
      </button>
    </div>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full">
      <thead class="bg-gradient-to-r from-amber-50 to-orange-50 border-b border-amber-200">
        <tr>
          <th class="px-4 py-3 text-center">
            <input 
              type="checkbox" 
              id="selectAll" 
              class="w-4 h-4 accent-amber-500 cursor-pointer"
              onchange="toggleSelectAll(this)"
            />
          </th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-amber-900 uppercase">Judul Tugas</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-amber-900 uppercase">Guru</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-amber-900 uppercase">Mata Pelajaran</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-amber-900 uppercase">Kelas</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-amber-900 uppercase">Deadline</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-amber-900 uppercase">Status</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-amber-900 uppercase">Submission</th>
          <th class="px-4 py-3 text-center text-xs font-semibold text-amber-900 uppercase">Aksi</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-amber-100">
        <% if (assignments.length === 0) { %>
          <tr>
            <td colspan="9" class="px-4 py-8 text-center text-slate-500">
              Tidak ada tugas ditemukan
            </td>
          </tr>
        <% } else { %>
          <% assignments.forEach(a => { %>
            <tr class="hover:bg-amber-50 transition-colors">
              <td class="px-4 py-3 text-center">
                <input 
                  type="checkbox" 
                  class="assignment-checkbox w-4 h-4 accent-amber-500 cursor-pointer" 
                  value="<%= a.id %>"
                  onchange="updateBulkActions()"
                />
              </td>
              <td class="px-4 py-3">
                <div class="font-semibold text-slate-900"><%= a.title %></div>
                <div class="text-xs text-slate-500 mt-1">Dibuat: <%= new Date(a.created_at).toLocaleDateString('id-ID') %></div>
              </td>
              <td class="px-4 py-3 text-sm text-slate-700"><%= a.teacher_name %></td>
              <td class="px-4 py-3 text-sm text-slate-700"><%= a.subject_name %></td>
              <td class="px-4 py-3 text-sm text-slate-700"><%= a.class_name || 'Semua Kelas' %></td>
              <td class="px-4 py-3 text-sm">
                <% if (a.due_date) { %>
                  <div class="text-slate-700"><%= new Date(a.due_date).toLocaleDateString('id-ID') %></div>
                  <div class="text-xs text-slate-500"><%= new Date(a.due_date).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %></div>
                <% } else { %>
                  <span class="text-slate-400">-</span>
                <% } %>
              </td>
              <td class="px-4 py-3">
                <% if (a.is_published) { %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-800">
                    Published
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-slate-100 text-slate-800">
                    Draft
                  </span>
                <% } %>
              </td>
              <td class="px-4 py-3 text-center">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-blue-100 text-blue-800">
                  <%= a.submission_count || 0 %>
                </span>
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center justify-center gap-2">
                  <a href="/admin/assignments/<%= a.id %>" class="px-3 py-1.5 rounded-lg bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white text-xs font-semibold transition-all">
                    Detail
                  </a>
                  <form method="POST" action="/admin/assignments/<%= a.id %>/delete" onsubmit="return confirm('Yakin ingin menghapus tugas ini?');" class="inline">
                    <button type="submit" class="px-3 py-1.5 rounded-lg bg-gradient-to-r from-red-500 to-red-600 hover:from-red-600 hover:to-red-700 text-white text-xs font-semibold transition-all">
                      Hapus
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<script>
  function toggleSelectAll(checkbox) {
    const checkboxes = document.querySelectorAll('.assignment-checkbox');
    checkboxes.forEach(cb => cb.checked = checkbox.checked);
    updateBulkActions();
  }

  function updateBulkActions() {
    const checkboxes = document.querySelectorAll('.assignment-checkbox:checked');
    const count = checkboxes.length;
    const bulkActions = document.getElementById('bulkActions');
    const selectedCount = document.getElementById('selectedCount');
    const selectAll = document.getElementById('selectAll');

    selectedCount.textContent = count;
    
    if (count > 0) {
      bulkActions.classList.remove('hidden');
    } else {
      bulkActions.classList.add('hidden');
    }

    // Update select all checkbox
    const allCheckboxes = document.querySelectorAll('.assignment-checkbox');
    selectAll.checked = allCheckboxes.length > 0 && count === allCheckboxes.length;
  }

  function bulkDelete() {
    const checkboxes = document.querySelectorAll('.assignment-checkbox:checked');
    const ids = Array.from(checkboxes).map(cb => cb.value);
    
    if (ids.length === 0) {
      alert('Pilih minimal 1 tugas untuk dihapus');
      return;
    }

    if (!confirm(`Yakin ingin menghapus ${ids.length} tugas terpilih?`)) {
      return;
    }

    // Create form and submit
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '/admin/assignments/bulk-delete';
    
    ids.forEach(id => {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'ids[]';
      input.value = id;
      form.appendChild(input);
    });
    
    document.body.appendChild(form);
    form.submit();
  }
</script>
