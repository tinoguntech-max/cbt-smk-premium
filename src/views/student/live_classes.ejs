<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-slate-800">Live Classes</h1>
    <p class="text-slate-600 mt-2">Ikuti kelas live dari guru Anda</p>
  </div>

  <!-- Live Classes List -->
  <div class="space-y-4">
    <% if (liveClasses.length === 0) { %>
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-12 text-center">
        <div class="text-6xl mb-4">📚</div>
        <h3 class="text-xl font-bold text-slate-800 mb-2">Belum Ada Live Class</h3>
        <p class="text-slate-600">Guru belum membuat live class untuk kelas Anda</p>
      </div>
    <% } else { %>
      <% liveClasses.forEach(liveClass => { %>
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 hover:shadow-md transition-shadow">
          <div class="flex items-start justify-between">
            <!-- Info -->
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-2">
                <h3 class="text-xl font-bold text-slate-800"><%= liveClass.title %></h3>
                <% if (liveClass.status === 'LIVE') { %>
                  <span class="px-3 py-1 bg-red-100 text-red-700 text-sm font-semibold rounded-full flex items-center gap-1">
                    <span class="w-2 h-2 bg-red-500 rounded-full animate-pulse"></span>
                    LIVE
                  </span>
                <% } else if (liveClass.status === 'SCHEDULED') { %>
                  <span class="px-3 py-1 bg-blue-100 text-blue-700 text-sm font-semibold rounded-full">
                    📅 Terjadwal
                  </span>
                <% } else if (liveClass.status === 'ENDED') { %>
                  <span class="px-3 py-1 bg-slate-100 text-slate-600 text-sm font-semibold rounded-full">
                    ✓ Selesai
                  </span>
                <% } else if (liveClass.status === 'CANCELLED') { %>
                  <span class="px-3 py-1 bg-red-100 text-red-700 text-sm font-semibold rounded-full">
                    ✗ Dibatalkan
                  </span>
                <% } %>
              </div>

              <div class="flex items-center gap-4 text-sm text-slate-600 mb-3">
                <span class="flex items-center gap-1">
                  📚 <%= liveClass.subject_name %>
                </span>
                <span class="flex items-center gap-1">
                  👨‍🏫 <%= liveClass.teacher_name %>
                </span>
                <span class="flex items-center gap-1">
                  ⏱️ <%= liveClass.duration_minutes %> menit
                </span>
                <% if (liveClass.status === 'LIVE') { %>
                  <span class="flex items-center gap-1">
                    👥 <%= liveClass.active_participants %> peserta
                  </span>
                <% } %>
              </div>

              <% if (liveClass.description) { %>
                <p class="text-slate-600 text-sm mb-3"><%= liveClass.description %></p>
              <% } %>

              <div class="flex items-center gap-4 text-sm">
                <span class="text-slate-500">
                  📅 <%= new Date(liveClass.scheduled_at).toLocaleDateString('id-ID', { 
                    weekday: 'long', 
                    year: 'numeric', 
                    month: 'long', 
                    day: 'numeric' 
                  }) %>
                </span>
                <span class="text-slate-500">
                  🕐 <%= new Date(liveClass.scheduled_at).toLocaleTimeString('id-ID', { 
                    hour: '2-digit', 
                    minute: '2-digit' 
                  }) %>
                </span>
              </div>

              <% if (liveClass.my_joined_at) { %>
                <div class="mt-3 flex items-center gap-2 text-sm text-green-600">
                  <span>✓</span>
                  <span>Anda sudah join pada <%= new Date(liveClass.my_joined_at).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %></span>
                </div>
              <% } %>
            </div>

            <!-- Actions -->
            <div class="ml-6">
              <% if (liveClass.status === 'LIVE' || liveClass.status === 'SCHEDULED') { %>
                <a href="/student/live-classes/<%= liveClass.id %>/join" 
                   class="px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl transition-colors inline-flex items-center gap-2">
                  <span>🎥</span>
                  <span>Join Live Class</span>
                </a>
              <% } else if (liveClass.status === 'ENDED') { %>
                <button disabled 
                        class="px-6 py-3 bg-slate-200 text-slate-500 font-semibold rounded-xl cursor-not-allowed">
                  Sudah Berakhir
                </button>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>
