<div class="flex items-center justify-between gap-4">
  <div>
    <div class="text-sm text-slate-500">Ujian</div>
    <h1 class="text-3xl font-semibold tracking-tight"><%= exam.title %></h1>
    <p class="mt-2 text-slate-600"><%= exam.description || '—' %></p>
  </div>
    <a href="/student/exams" class="text-sm px-4 py-2 rounded-xl border border-rose-200 bg-gradient-to-br from-rose-50 to-pink-100 hover:from-rose-100 hover:to-pink-200 text-rose-800 font-medium transition-all">Kembali</a>
</div>

<!-- Flash Messages -->
<% if (flash.error && flash.error.length) { %>
  <div class="mt-4 rounded-xl bg-red-50 border border-red-200 p-4">
    <div class="flex items-start gap-3">
      <svg class="w-5 h-5 text-red-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <div class="flex-1">
        <% flash.error.forEach(msg => { %>
          <p class="text-sm text-red-800"><%= msg %></p>
        <% }) %>
      </div>
    </div>
  </div>
<% } %>

<% if (flash.info && flash.info.length) { %>
  <div class="mt-4 rounded-xl bg-blue-50 border border-blue-200 p-4">
    <div class="flex items-start gap-3">
      <svg class="w-5 h-5 text-blue-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <div class="flex-1">
        <% flash.info.forEach(msg => { %>
          <p class="text-sm text-blue-800"><%= msg %></p>
        <% }) %>
      </div>
    </div>
  </div>
<% } %>

<% if (flash.success && flash.success.length) { %>
  <div class="mt-4 rounded-xl bg-green-50 border border-green-200 p-4">
    <div class="flex items-start gap-3">
      <svg class="w-5 h-5 text-green-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <div class="flex-1">
        <% flash.success.forEach(msg => { %>
          <p class="text-sm text-green-800"><%= msg %></p>
        <% }) %>
      </div>
    </div>
  </div>
<% } %>

<div class="mt-6 grid lg:grid-cols-3 gap-4">
  <div class="rounded-2xl border-2 border-purple-200 bg-gradient-to-br from-purple-50 via-pink-50 to-purple-100 p-6 shadow-lg">
    <div class="flex items-center gap-2 mb-4">
      <div class="text-2xl">📊</div>
      <div class="text-lg font-bold text-purple-900">Info Ujian</div>
    </div>
    <div class="space-y-3 text-sm">
      <div class="flex justify-between items-center p-2 rounded-lg bg-white/50">
        <span class="text-purple-700 font-medium">👨‍🏫 Guru</span>
        <span class="text-purple-900 font-semibold"><%= exam.teacher_name %></span>
      </div>
      <div class="flex justify-between items-center p-2 rounded-lg bg-white/50">
        <span class="text-purple-700 font-medium">📚 Mapel</span>
        <span class="text-purple-900 font-semibold"><%= exam.subject_name %></span>
      </div>
      <div class="flex justify-between items-center p-2 rounded-lg bg-white/50">
        <span class="text-purple-700 font-medium">📝 Jumlah soal</span>
        <span class="text-purple-900 font-semibold"><%= exam.question_count %> soal</span>
      </div>
      <div class="flex justify-between items-center p-2 rounded-lg bg-white/50">
        <span class="text-purple-700 font-medium">⏱️ Durasi</span>
        <span class="text-purple-900 font-semibold"><%= exam.duration_minutes %> menit</span>
      </div>
      <div class="flex justify-between items-center p-2 rounded-lg bg-white/50">
        <span class="text-purple-700 font-medium">🎯 KKM</span>
        <span class="text-purple-900 font-semibold"><%= exam.pass_score %></span>
      </div>
      <div class="flex justify-between items-center p-2 rounded-lg bg-white/50">
        <span class="text-purple-700 font-medium">🔄 Maks percobaan</span>
        <span class="text-purple-900 font-semibold"><%= exam.max_attempts %>x</span>
      </div>
      <div class="flex justify-between items-center p-2 rounded-lg bg-white/50">
        <span class="text-purple-700 font-medium">✅ Sudah mencoba</span>
        <span class="text-purple-900 font-semibold"><%= exam.attempts_count %>x</span>
      </div>
      <% if (exam.start_at) { %>
        <div class="flex justify-between items-center p-2 rounded-lg bg-white/50">
          <span class="text-purple-700 font-medium">🚀 Mulai</span>
          <span class="text-purple-900 font-semibold text-xs"><%= new Date(exam.start_at).toLocaleString('id-ID', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %></span>
        </div>
      <% } %>
      <% if (exam.end_at) { %>
        <div class="flex justify-between items-center p-2 rounded-lg bg-white/50">
          <span class="text-purple-700 font-medium">🏁 Selesai</span>
          <span class="text-purple-900 font-semibold text-xs"><%= new Date(exam.end_at).toLocaleString('id-ID', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %></span>
        </div>
      <% } %>
    </div>
  </div>

  <% if (exam.attempts_count >= exam.max_attempts) { %>
    <!-- Show Results Card when max attempts reached -->
    <div class="lg:col-span-2 rounded-2xl border-2 border-amber-200 bg-gradient-to-br from-amber-50 via-yellow-50 to-amber-100 p-6 shadow-lg">
      <div class="flex items-center gap-2 mb-3">
        <div class="text-3xl">📊</div>
        <h2 class="text-2xl font-bold text-amber-900">Hasil Ujian</h2>
      </div>
      <p class="text-sm text-amber-700 bg-white/50 p-3 rounded-lg mb-4">
        ⚠️ Anda telah mencapai batas maksimal percobaan (<%= exam.max_attempts %>x)
      </p>

      <% if (attemptResults && attemptResults.length > 0) { %>
        <div class="space-y-3">
          <% attemptResults.forEach((attempt, index) => { %>
            <div class="p-4 rounded-xl bg-white/70 border-2 <%= attempt.status === 'Lulus' ? 'border-green-300' : 'border-red-300' %>">
              <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-semibold text-slate-700">Percobaan #<%= index + 1 %></span>
                <span class="px-3 py-1 rounded-full text-xs font-bold <%= attempt.status === 'Lulus' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                  <%= attempt.status %>
                </span>
              </div>
              <div class="flex items-center justify-between">
                <div>
                  <div class="text-3xl font-bold <%= attempt.status === 'Lulus' ? 'text-green-600' : 'text-red-600' %>">
                    <%= attempt.score %>
                  </div>
                  <div class="text-xs text-slate-500">KKM: <%= exam.pass_score %></div>
                </div>
                <div class="text-right">
                  <div class="text-xs text-slate-500">Dikumpulkan</div>
                  <div class="text-sm font-medium text-slate-700">
                    <%= new Date(attempt.finished_at).toLocaleString('id-ID', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
        
        <div class="mt-4 p-4 rounded-xl bg-gradient-to-r from-indigo-100 to-purple-100 border-2 border-indigo-300">
          <div class="flex items-center justify-between">
            <div>
              <div class="text-sm font-semibold text-indigo-900">🏆 Nilai Terbaik</div>
              <div class="text-3xl font-bold text-indigo-600 mt-1"><%= attemptResults[0].score %></div>
            </div>
            <div class="text-right">
              <a href="/student/history" class="inline-block px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium transition-colors">
                Lihat Riwayat Lengkap
              </a>
            </div>
          </div>
        </div>
      <% } else { %>
        <div class="p-4 rounded-xl bg-white/70 border-2 border-slate-300 text-center">
          <div class="text-slate-500">Tidak ada hasil ujian ditemukan</div>
        </div>
      <% } %>
    </div>
  <% } else { %>
    <!-- Show Start Exam Card when attempts available -->
    <div class="lg:col-span-2 rounded-2xl border-2 border-indigo-200 bg-gradient-to-br from-indigo-50 via-blue-50 to-indigo-100 p-6 shadow-lg">
      <div class="flex items-center gap-2 mb-3">
        <div class="text-3xl">🎯</div>
        <h2 class="text-2xl font-bold text-indigo-900">Mulai Ujian</h2>
      </div>
      <p class="text-sm text-indigo-700 bg-white/50 p-3 rounded-lg">
        ⚡ Pastikan koneksi internet stabil. Timer akan berjalan otomatis setelah ujian dimulai!
      </p>

      <form action="/student/exams/<%= exam.id %>/start" method="POST" class="mt-5 space-y-4">
        <% if (exam.access_code) { %>
          <div>
            <label class="text-sm font-semibold text-indigo-900 flex items-center gap-2">
              <span>🔐</span>
              <span>Kode Akses</span>
            </label>
            <input name="access_code" required class="mt-2 w-full rounded-xl bg-white border-2 border-indigo-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 font-medium" placeholder="Masukkan kode dari guru" />
          </div>
        <% } %>

        <button class="w-full sm:w-auto rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white font-bold px-8 py-4 shadow-lg hover:shadow-xl transition-all transform hover:scale-105">
          🚀 Mulai Ujian Sekarang!
        </button>
        <div class="text-xs text-indigo-700 bg-white/50 p-3 rounded-lg">
          ⚠️ Dengan klik mulai, Anda menyetujui aturan ujian (tidak menutup tab, tidak reload berulang).
        </div>
      </form>
    </div>
  <% } %>
</div>
