<div class="flex items-center justify-between gap-4">
  <div>
    <h1 class="text-3xl font-semibold tracking-tight">Riwayat Materi</h1>
    <p class="mt-1 text-slate-600">Maks. 100 materi terbaru yang pernah dibuka.</p>
  </div>
</div>

<div class="mt-4 flex flex-wrap gap-2">
  <a href="/student/exams" class="px-4 py-2 rounded-xl border border-indigo-200 bg-gradient-to-br from-indigo-50 to-indigo-100 hover:from-indigo-100 hover:to-indigo-200 text-indigo-800 font-medium transition-all">Ujian</a>
  <a href="/student/materials" class="px-4 py-2 rounded-xl border border-teal-200 bg-gradient-to-br from-teal-50 to-teal-100 hover:from-teal-100 hover:to-teal-200 text-teal-800 font-medium transition-all">Materi</a>
  <a href="/student/history" class="px-4 py-2 rounded-xl border border-purple-200 bg-gradient-to-br from-purple-50 to-purple-100 hover:from-purple-100 hover:to-purple-200 text-purple-800 font-medium transition-all">Riwayat Ujian</a>
</div>

<div class="mt-6 rounded-2xl border border-teal-200 bg-gradient-to-br from-teal-50 to-teal-100 p-5 overflow-x-auto">
  <table class="w-full text-sm">
    <thead class="text-teal-700">
      <tr>
        <th class="text-left py-2">Materi</th>
        <th class="text-left py-2">Mapel</th>
        <th class="text-left py-2">Kelas</th>
        <th class="text-left py-2">Status</th>
        <th class="text-left py-2">Terakhir Dibuka</th>
        <th class="text-right py-2">Aksi</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-teal-200">
      <% if (!rows.length) { %>
        <tr>
          <td colspan="6" class="py-8 text-center text-teal-700">Belum ada riwayat materi.</td>
        </tr>
      <% } %>
      <% rows.forEach(r => { %>
        <tr>
          <td class="py-3 text-teal-900 font-medium"><%= r.material_title %></td>
          <td class="py-3 text-teal-800"><%= r.subject_name %></td>
          <td class="py-3 text-teal-800"><%= r.class_name || 'Semua' %></td>
          <td class="py-3">
            <% if (r.completed_at) { %>
              <span class="px-2 py-1 rounded-lg border border-emerald-300 bg-emerald-100 text-emerald-700 font-medium text-xs">Selesai</span>
            <% } else { %>
              <span class="px-2 py-1 rounded-lg border border-sky-300 bg-sky-100 text-sky-700 font-medium text-xs">Sudah dibaca</span>
            <% } %>
          </td>
          <td class="py-3 text-teal-700 text-xs"><%= new Date(r.last_opened_at).toLocaleString('id-ID') %></td>
          <td class="py-3 text-right">
            <a href="/student/materials/<%= r.material_id %>" class="px-3 py-2 rounded-lg border border-teal-300 bg-white hover:bg-teal-50 text-teal-800 font-medium transition-colors">Buka</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
