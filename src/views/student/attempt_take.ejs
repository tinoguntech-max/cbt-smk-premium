<% const totalQ = questions.length; %>

<!-- Header dengan gradient ceria -->
<div class="rounded-2xl border border-indigo-200 bg-gradient-to-br from-indigo-50 via-purple-50 to-pink-50 p-6 shadow-lg mb-6">
  <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4">
    <div class="flex-1">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/80 backdrop-blur-sm text-xs font-semibold text-indigo-600 mb-2">
        📝 Sedang Mengerjakan Ujian
      </div>
      <h1 class="text-3xl font-bold text-indigo-900"><%= attempt.title %></h1>
      <% if (attempt.description) { %>
        <p class="mt-2 text-indigo-700"><%= attempt.description %></p>
      <% } %>
    </div>

    <!-- Timer Card -->
    <div class="rounded-xl border-2 border-rose-300 bg-gradient-to-br from-rose-50 to-orange-50 p-4 w-full lg:w-64 shadow-md">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-2xl">⏰</span>
        <div class="text-xs font-semibold text-rose-700">Sisa Waktu</div>
      </div>
      <div id="timer" class="text-4xl font-bold text-rose-600 tabular-nums">--:--</div>
      <div class="mt-3 flex items-center justify-between text-xs">
        <span class="text-rose-600">Terjawab:</span>
        <span class="font-bold text-rose-700"><span id="answeredCount">0</span>/<%= totalQ %></span>
      </div>
      <form action="/student/attempts/<%= attempt.id %>/submit" method="POST" id="submitForm" class="mt-4">
        <button class="w-full rounded-xl bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-600 hover:to-teal-700 text-white font-bold py-3 shadow-lg hover:shadow-xl transition-all transform hover:scale-105">
          ✅ Kumpulkan Jawaban
        </button>
      </form>
    </div>
  </div>
</div>

<!-- Anti-cheat bar -->
<div id="antiCheatBar" class="rounded-xl border border-amber-300 bg-gradient-to-r from-amber-50 to-yellow-50 px-5 py-4 mb-6 shadow-md">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div class="flex items-start gap-3">
      <span class="text-3xl">🔒</span>
      <div>
        <div class="font-bold text-amber-900">Mode Ujian Aktif</div>
        <div class="text-sm text-amber-700">Disarankan aktifkan fullscreen dan jangan pindah tab. Pelanggaran akan tercatat.</div>
      </div>
    </div>
    <button id="btnFullscreen" type="button" class="px-5 py-2.5 rounded-xl bg-gradient-to-r from-amber-500 to-orange-500 hover:from-amber-600 hover:to-orange-600 text-white font-bold shadow-md hover:shadow-lg transition-all whitespace-nowrap">
      🖥️ Fullscreen
    </button>
  </div>
</div>

<div class="grid lg:grid-cols-12 gap-6">
  <!-- Navigasi Soal - Sticky -->
  <div class="lg:col-span-4">
    <div class="lg:sticky lg:top-4 rounded-2xl border border-purple-200 bg-gradient-to-br from-purple-50 to-pink-50 p-5 shadow-lg">
      <div class="flex items-center gap-2 mb-4">
        <span class="text-2xl">🧭</span>
        <h2 class="text-lg font-bold text-purple-900">Navigasi Soal</h2>
      </div>
      
      <div class="grid grid-cols-5 gap-2 max-h-[60vh] overflow-y-auto pr-2" style="scrollbar-width: thin;">
        <% questions.forEach((q) => { %>
          <button type="button" data-jump="q-<%= q.no %>" class="navBtn h-12 rounded-xl border-2 font-bold text-sm transition-all transform hover:scale-110 <%= q.chosen_option_id ? 'border-emerald-400 bg-gradient-to-br from-emerald-100 to-teal-100 text-emerald-700 shadow-md' : 'border-slate-300 bg-white text-slate-600 hover:bg-slate-50' %>">
            <%= q.no %>
          </button>
        <% }) %>
      </div>
      
      <div class="mt-4 pt-4 border-t border-purple-200 space-y-2">
        <div class="flex items-center gap-2 text-xs">
          <div class="w-6 h-6 rounded-lg bg-gradient-to-br from-emerald-100 to-teal-100 border-2 border-emerald-400"></div>
          <span class="text-purple-700">Sudah dijawab</span>
        </div>
        <div class="flex items-center gap-2 text-xs">
          <div class="w-6 h-6 rounded-lg bg-white border-2 border-slate-300"></div>
          <span class="text-purple-700">Belum dijawab</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Soal-soal -->
  <div class="lg:col-span-8 space-y-6">
    <% questions.forEach((q, idx) => { 
      const colors = [
        { border: 'border-blue-200', bg: 'from-blue-50 to-cyan-50', text: 'text-blue-900', badge: 'bg-blue-100 text-blue-700' },
        { border: 'border-purple-200', bg: 'from-purple-50 to-pink-50', text: 'text-purple-900', badge: 'bg-purple-100 text-purple-700' },
        { border: 'border-rose-200', bg: 'from-rose-50 to-pink-50', text: 'text-rose-900', badge: 'bg-rose-100 text-rose-700' },
        { border: 'border-emerald-200', bg: 'from-emerald-50 to-teal-50', text: 'text-emerald-900', badge: 'bg-emerald-100 text-emerald-700' },
        { border: 'border-amber-200', bg: 'from-amber-50 to-orange-50', text: 'text-amber-900', badge: 'bg-amber-100 text-amber-700' },
        { border: 'border-indigo-200', bg: 'from-indigo-50 to-purple-50', text: 'text-indigo-900', badge: 'bg-indigo-100 text-indigo-700' }
      ];
      const color = colors[idx % colors.length];
    %>
      <section id="q-<%= q.no %>" class="rounded-2xl border-2 <%= color.border %> bg-gradient-to-br <%= color.bg %> p-6 shadow-lg scroll-mt-6">
        <div class="flex items-start justify-between gap-4 mb-4">
          <div class="flex items-center gap-3">
            <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-white shadow-md">
              <span class="text-xl font-bold <%= color.text %>"><%= q.no %></span>
            </div>
            <div>
              <div class="text-xs font-semibold <%= color.text %> opacity-75">Soal <%= q.no %> dari <%= totalQ %></div>
              <div class="inline-flex items-center gap-1 px-3 py-1 rounded-full <%= color.badge %> text-xs font-bold mt-1">
                ⭐ <%= q.points %> poin
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-xl p-5 shadow-md mb-4">
          <div class="text-slate-900 leading-relaxed prose prose-sm max-w-none"><%- q.text %></div>
          <% if (q.image) { %>
            <div class="mt-4">
              <img src="<%= q.image %>" alt="Gambar soal" class="max-w-full rounded-xl border-2 <%= color.border %> shadow-md" loading="lazy" />
            </div>
          <% } %>
          <% if (q.pdf) { %>
            <div class="mt-4">
              <div class="text-xs font-semibold <%= color.text %> mb-2">📄 PDF Soal:</div>
              <iframe src="<%= q.pdf %>" class="w-full h-96 rounded-xl border-2 <%= color.border %> shadow-md" frameborder="0"></iframe>
            </div>
          <% } %>
        </div>

        <div class="space-y-3">
          <div class="text-sm font-bold <%= color.text %> mb-2">Pilih Jawaban:</div>
          <% q.options.forEach((o) => { %>
            <label class="block rounded-xl border-2 <%= q.chosen_option_id === o.id ? color.border + ' bg-white shadow-lg' : 'border-slate-200 bg-white/80' %> hover:shadow-lg px-5 py-4 cursor-pointer transition-all transform hover:scale-[1.02]">
              <div class="flex gap-4">
                <input type="radio" name="ans_<%= q.id %>" value="<%= o.id %>" data-question="<%= q.id %>" class="mt-1 w-5 h-5 accent-<%= color.text.replace('text-', '') %>" <%= (q.chosen_option_id === o.id) ? 'checked' : '' %> />
                <div class="flex-1">
                  <div class="inline-flex items-center justify-center w-8 h-8 rounded-lg <%= color.badge %> font-bold text-sm mb-2">
                    <%= o.option_label %>
                  </div>
                  <div class="text-slate-700 prose prose-sm max-w-none"><%- o.option_text %></div>
                </div>
              </div>
            </label>
          <% }) %>
        </div>
      </section>
    <% }) %>
  </div>
</div>

<script>
  // ===== CLIENT-SIDE BACKUP SYSTEM =====
  const BACKUP_KEY = 'exam_backup_<%= attempt.id %>';
  const SUBMISSION_RETRY_KEY = 'submission_retry_<%= attempt.id %>';
  
  // Save answers to LocalStorage
  function saveBackupToLocalStorage() {
    const answers = [];
    document.querySelectorAll('input[type=radio]:checked').forEach(radio => {
      answers.push({
        question_id: Number(radio.getAttribute('data-question')),
        option_id: Number(radio.value),
        answered_at: new Date().toISOString()
      });
    });
    
    const backup = {
      attempt_id: <%= attempt.id %>,
      student_id: <%= attempt.student_id %>,
      exam_id: <%= attempt.exam_id %>,
      answers: answers,
      backup_timestamp: new Date().toISOString()
    };
    
    try {
      localStorage.setItem(BACKUP_KEY, JSON.stringify(backup));
      console.log('✅ Backup saved to LocalStorage:', answers.length, 'answers');
    } catch (e) {
      console.error('❌ Failed to save backup:', e);
    }
  }
  
  // Load backup from LocalStorage on page load
  function loadBackupFromLocalStorage() {
    try {
      const backupStr = localStorage.getItem(BACKUP_KEY);
      if (backupStr) {
        const backup = JSON.parse(backupStr);
        console.log('📦 Found backup in LocalStorage:', backup.answers.length, 'answers');
        return backup;
      }
    } catch (e) {
      console.error('❌ Failed to load backup:', e);
    }
    return null;
  }
  
  // Clear backup after successful submission
  function clearBackup() {
    try {
      localStorage.removeItem(BACKUP_KEY);
      localStorage.removeItem(SUBMISSION_RETRY_KEY);
      console.log('🗑️ Backup cleared from LocalStorage');
    } catch (e) {
      console.error('❌ Failed to clear backup:', e);
    }
  }
  
  // Timer
  const startedAt = new Date('<%= attempt.started_at.toISOString ? attempt.started_at.toISOString() : attempt.started_at %>');
  const durationMinutes = Number('<%= attempt.duration_minutes %>');
  const endAt = new Date(startedAt.getTime() + durationMinutes * 60 * 1000);

  function formatMs(ms) {
    const totalSeconds = Math.max(0, Math.floor(ms / 1000));
    const m = Math.floor(totalSeconds / 60);
    const s = totalSeconds % 60;
    return String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
  }

  let timeUpSubmitted = false;
  
  function tick() {
    const now = new Date();
    const remain = endAt - now;
    const timerEl = document.getElementById('timer');
    timerEl.textContent = formatMs(remain);
    
    // Warning saat 5 menit tersisa
    if (remain <= 300000 && remain > 299000) {
      toast('⏰ Perhatian! Waktu tersisa 5 menit!');
    }
    
    // Warning saat 1 menit tersisa
    if (remain <= 60000 && remain > 59000) {
      toast('⚠️ Waktu tersisa 1 menit! Segera selesaikan!');
      timerEl.classList.add('animate-pulse');
    }
    
    // Auto-submit saat waktu habis
    if (remain <= 0 && !timeUpSubmitted) {
      timeUpSubmitted = true;
      timerEl.textContent = '00:00';
      
      // Tampilkan notifikasi
      const notification = document.createElement('div');
      notification.className = 'fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm';
      notification.innerHTML = `
        <div class="rounded-2xl border-2 border-rose-300 bg-gradient-to-br from-rose-50 to-pink-50 p-8 shadow-2xl max-w-md mx-4 text-center">
          <div class="text-6xl mb-4">⏰</div>
          <h2 class="text-2xl font-bold text-rose-900 mb-2">Waktu Habis!</h2>
          <p class="text-rose-700 mb-4">Jawaban Anda sedang dikumpulkan secara otomatis...</p>
          <div class="flex items-center justify-center gap-2">
            <div class="w-3 h-3 bg-rose-500 rounded-full animate-bounce" style="animation-delay: 0s"></div>
            <div class="w-3 h-3 bg-rose-500 rounded-full animate-bounce" style="animation-delay: 0.1s"></div>
            <div class="w-3 h-3 bg-rose-500 rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
          </div>
        </div>
      `;
      document.body.appendChild(notification);
      
      // Use retry mechanism for auto-submit
      setTimeout(() => {
        submitWithRetry();
      }, 1500);
    }
  }
  setInterval(tick, 500);
  tick();

  // Navigasi dengan highlight active
  const navButtons = document.querySelectorAll('.navBtn');
  const sections = document.querySelectorAll('section[id^="q-"]');
  
  // Scroll to question
  navButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-jump');
      const el = document.getElementById(id);
      if (el) {
        el.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    });
  });

  // Highlight active question in navigation
  function updateActiveNav() {
    const scrollPos = window.scrollY + window.innerHeight / 3;
    
    let activeSection = null;
    sections.forEach(section => {
      const rect = section.getBoundingClientRect();
      const sectionTop = rect.top + window.scrollY;
      const sectionBottom = sectionTop + rect.height;
      
      if (scrollPos >= sectionTop && scrollPos < sectionBottom) {
        activeSection = section;
      }
    });

    navButtons.forEach(btn => {
      const targetId = btn.getAttribute('data-jump');
      if (activeSection && targetId === activeSection.id) {
        btn.classList.add('ring-4', 'ring-purple-400', 'ring-offset-2');
      } else {
        btn.classList.remove('ring-4', 'ring-purple-400', 'ring-offset-2');
      }
    });
  }

  window.addEventListener('scroll', updateActiveNav);
  updateActiveNav();

  // Hitung answered
  function updateAnswered() {
    const answered = document.querySelectorAll('input[type=radio]:checked').length;
    document.getElementById('answeredCount').textContent = answered;
    
    // Update nav button colors
    document.querySelectorAll('input[type=radio]:checked').forEach(radio => {
      const qid = radio.getAttribute('data-question');
      const qNo = radio.closest('section').id.replace('q-', '');
      const navBtn = document.querySelector(`[data-jump="q-${qNo}"]`);
      if (navBtn) {
        navBtn.classList.remove('border-slate-300', 'bg-white', 'text-slate-600');
        navBtn.classList.add('border-emerald-400', 'bg-gradient-to-br', 'from-emerald-100', 'to-teal-100', 'text-emerald-700', 'shadow-md');
      }
    });
  }
  updateAnswered();

  // Autosave jawaban
  document.querySelectorAll('input[type=radio]').forEach(r => {
    r.addEventListener('change', async () => {
      const qid = r.getAttribute('data-question');
      const oid = r.value;
      updateAnswered();

      // Save to LocalStorage immediately
      saveBackupToLocalStorage();

      try {
        await fetch('/student/attempts/<%= attempt.id %>/answer', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question_id: Number(qid), option_id: Number(oid) })
        });
      } catch (e) {
        console.error('Autosave failed:', e);
        toast('⚠️ Koneksi terputus. Jawaban tersimpan di perangkat Anda.');
      }
    });
  });

  // ===== SUBMISSION WITH RETRY MECHANISM =====
  let isSubmitting = false;
  
  async function submitWithRetry(maxRetries = 3) {
    if (isSubmitting) {
      console.log('⏳ Submission already in progress');
      return;
    }
    
    isSubmitting = true;
    
    // Save final backup before submission
    saveBackupToLocalStorage();
    
    let retryCount = 0;
    let lastError = null;
    
    while (retryCount < maxRetries) {
      try {
        console.log(`🔄 Submission attempt ${retryCount + 1}/${maxRetries}`);
        
        const response = await fetch('/student/attempts/<%= attempt.id %>/submit', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Retry-Count': retryCount.toString()
          },
          body: JSON.stringify({
            backup_data: loadBackupFromLocalStorage()
          })
        });
        
        if (response.ok || response.status === 302) {
          console.log('✅ Submission successful!');
          clearBackup();
          
          // Redirect to result page
          window.location.href = `/student/attempts/<%= attempt.id %>/result`;
          return;
        }
        
        // If server returns error, throw to trigger retry
        throw new Error(`Server returned ${response.status}`);
        
      } catch (error) {
        lastError = error;
        retryCount++;
        
        console.error(`❌ Submission attempt ${retryCount} failed:`, error);
        
        if (retryCount < maxRetries) {
          // Exponential backoff: 1s, 2s, 4s
          const delay = Math.pow(2, retryCount - 1) * 1000;
          console.log(`⏳ Retrying in ${delay}ms...`);
          
          toast(`Gagal submit, mencoba lagi... (${retryCount}/${maxRetries})`);
          
          await new Promise(resolve => setTimeout(resolve, delay));
        }
      }
    }
    
    // All retries failed
    console.error('❌ All submission attempts failed');
    isSubmitting = false;
    
    // Show error message with recovery instructions
    const errorDiv = document.createElement('div');
    errorDiv.className = 'fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm';
    errorDiv.innerHTML = `
      <div class="rounded-2xl border-2 border-rose-300 bg-gradient-to-br from-rose-50 to-pink-50 p-8 shadow-2xl max-w-md mx-4">
        <div class="text-6xl mb-4 text-center">⚠️</div>
        <h2 class="text-2xl font-bold text-rose-900 mb-2 text-center">Submission Gagal</h2>
        <p class="text-rose-700 mb-4 text-center">
          Jawaban Anda telah tersimpan dengan aman di perangkat dan server. 
          Silakan hubungi guru atau admin untuk memulihkan jawaban Anda.
        </p>
        <div class="bg-white rounded-lg p-4 mb-4 text-sm">
          <div class="font-bold text-gray-900 mb-2">📋 Informasi untuk Admin:</div>
          <div class="text-gray-700">
            <div>Attempt ID: <span class="font-mono font-bold"><%= attempt.id %></span></div>
            <div>Backup tersimpan di LocalStorage</div>
            <div>Waktu: ${new Date().toLocaleString('id-ID')}</div>
          </div>
        </div>
        <button onclick="location.reload()" 
                class="w-full rounded-xl bg-gradient-to-r from-blue-500 to-indigo-600 hover:from-blue-600 hover:to-indigo-700 text-white font-bold py-3 shadow-lg">
          🔄 Coba Lagi
        </button>
        <button onclick="window.location.href='/student/exams'" 
                class="w-full mt-2 rounded-xl bg-gray-500 hover:bg-gray-600 text-white font-bold py-3 shadow-lg">
          ← Kembali ke Daftar Ujian
        </button>
      </div>
    `;
    document.body.appendChild(errorDiv);
  }
  
  // Override form submission to use retry mechanism
  const submitForm = document.getElementById('submitForm');
  submitForm.addEventListener('submit', (e) => {
    e.preventDefault();
    
    const confirmed = confirm('Yakin ingin mengumpulkan jawaban? Pastikan semua soal sudah dijawab.');
    if (confirmed) {
      submitWithRetry();
    }
  });

  // Autosave jawaban
  document.querySelectorAll('input[type=radio]').forEach(r => {
    r.addEventListener('change', async () => {
      const qid = r.getAttribute('data-question');
      const oid = r.value;
      updateAnswered();

      try {
        await fetch('/student/attempts/<%= attempt.id %>/answer', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question_id: Number(qid), option_id: Number(oid) })
        });
      } catch (e) {
        console.error('Autosave failed:', e);
      }
    });
  });

  // Anti-cheat
  const anti = {
    attemptId: <%= attempt.id %>,
    max: Number('<%= process.env.ANTI_CHEAT_MAX_VIOLATIONS || 3 %>'),
    sentAt: new Map(),
    localCount: 0,
    locked: false
  };

  function nowMs() { return Date.now(); }

  function toast(msg) {
    let box = document.getElementById('antiCheatToast');
    if (!box) {
      box = document.createElement('div');
      box.id = 'antiCheatToast';
      box.className = 'fixed bottom-4 right-4 z-50 max-w-md rounded-xl border-2 border-rose-300 bg-gradient-to-r from-rose-50 to-pink-50 shadow-2xl px-5 py-4 text-sm font-semibold text-rose-900';
      document.body.appendChild(box);
    }
    box.textContent = '⚠️ ' + msg;
    box.style.opacity = '1';
    clearTimeout(box._t);
    box._t = setTimeout(() => { box.style.opacity = '0'; }, 3000);
  }

  async function reportViolation(type, details) {
    if (anti.locked) return;
    const key = type + '::' + (details || '');
    const last = anti.sentAt.get(key) || 0;
    if (nowMs() - last < 2000) return;
    anti.sentAt.set(key, nowMs());
    anti.localCount += 1;

    try {
      const r = await fetch(`/student/attempts/${anti.attemptId}/violation`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type, details })
      });
      const j = await r.json().catch(() => ({}));
      const count = (typeof j.count === 'number') ? j.count : anti.localCount;
      const max = (typeof j.max === 'number') ? j.max : anti.max;

      if (j.locked) {
        anti.locked = true;
        toast(`Attempt dikunci karena terlalu banyak pelanggaran (${count}/${max}). Jawaban akan dikumpulkan.`);
        setTimeout(() => {
          window.location.href = `/student/attempts/${anti.attemptId}/result`;
        }, 1200);
        return;
      }
      toast(`${type}. Pelanggaran tercatat (${count}/${max}).`);
    } catch (e) {
      toast(`${type}. (Gagal kirim log, cek koneksi)`);
    }
  }

  // Fullscreen
  const fsBtn = document.getElementById('btnFullscreen');
  async function requestFullscreen() {
    try {
      const el = document.documentElement;
      if (el.requestFullscreen) await el.requestFullscreen();
      else if (el.webkitRequestFullscreen) el.webkitRequestFullscreen();
    } catch (e) {
      toast('Browser menolak fullscreen.');
    }
  }
  if (fsBtn) fsBtn.addEventListener('click', requestFullscreen);

  let firstInteract = true;
  window.addEventListener('pointerdown', () => {
    if (!firstInteract) return;
    firstInteract = false;
    requestFullscreen();
  }, { once: true });

  function isFullscreen() {
    return !!(document.fullscreenElement || document.webkitFullscreenElement);
  }
  document.addEventListener('fullscreenchange', () => {
    if (!isFullscreen()) reportViolation('Keluar Fullscreen', 'fullscreenchange');
  });
  document.addEventListener('webkitfullscreenchange', () => {
    if (!isFullscreen()) reportViolation('Keluar Fullscreen', 'webkitfullscreenchange');
  });

  document.addEventListener('visibilitychange', () => {
    if (document.hidden) reportViolation('Pindah Tab/Aplikasi', 'visibilitychange');
  });
  window.addEventListener('blur', () => reportViolation('Pindah Tab/Aplikasi', 'blur'));

  document.addEventListener('contextmenu', (e) => {
    e.preventDefault();
    reportViolation('Klik Kanan', 'contextmenu');
  });
  ['copy','cut','paste'].forEach(ev => {
    document.addEventListener(ev, (e) => {
      e.preventDefault();
      reportViolation('Copy/Cut/Paste', ev);
    });
  });
  document.addEventListener('keydown', (e) => {
    const k = (e.key || '').toLowerCase();
    const ctrl = e.ctrlKey || e.metaKey;
    if (ctrl && ['c','v','x','p','s','u'].includes(k)) {
      e.preventDefault();
      reportViolation('Shortcut Diblokir', `ctrl+${k}`);
    }
    if (k === 'printscreen') {
      reportViolation('PrintScreen', 'key');
    }
  });

  try { document.body.style.userSelect = 'none'; } catch (e) {}
</script>
