<div class="flex items-center justify-between gap-4">
  <div>
    <h1 class="text-3xl font-semibold tracking-tight">Materi</h1>
    <p class="mt-1 text-slate-600">Materi yang tersedia untuk kelas Anda.</p>
  </div>
</div>

<div class="mt-4 flex flex-wrap gap-2">
  <a href="/student/exams" class="px-4 py-2 rounded-xl border border-indigo-200 bg-gradient-to-br from-indigo-50 to-indigo-100 hover:from-indigo-100 hover:to-indigo-200 text-indigo-800 font-medium transition-all">Ujian</a>
  <a href="/student/live-classes" class="px-4 py-2 rounded-xl border border-red-200 bg-gradient-to-br from-red-50 to-red-100 hover:from-red-100 hover:to-red-200 text-red-800 font-medium transition-all">🎥 Live Classes</a>
  <a href="/student/history" class="px-4 py-2 rounded-xl border border-purple-200 bg-gradient-to-br from-purple-50 to-purple-100 hover:from-purple-100 hover:to-purple-200 text-purple-800 font-medium transition-all">Riwayat Ujian</a>
  <a href="/student/material-history" class="px-4 py-2 rounded-xl border border-cyan-200 bg-gradient-to-br from-cyan-50 to-cyan-100 hover:from-cyan-100 hover:to-cyan-200 text-cyan-800 font-medium transition-all">Riwayat Materi</a>
</div>

<div class="mt-6 grid md:grid-cols-2 gap-4">
  <% if (!materials.length) { %>
    <div class="rounded-2xl border border-teal-200 bg-gradient-to-br from-teal-50 to-teal-100 p-8 text-center shadow-soft">
      <div class="text-4xl mb-2">📖</div>
      <div class="text-teal-900 font-semibold">Belum ada materi.</div>
      <div class="mt-1 text-sm text-teal-600">Materi akan segera tersedia!</div>
    </div>
  <% } %>
  <% materials.forEach((m, index) => { 
    const colors = [
      { border: 'border-teal-200', bg: 'from-teal-50 to-teal-100', hover: 'hover:shadow-teal-200', text: 'text-teal-900', subtext: 'text-teal-700', light: 'text-teal-600' },
      { border: 'border-indigo-200', bg: 'from-indigo-50 to-indigo-100', hover: 'hover:shadow-indigo-200', text: 'text-indigo-900', subtext: 'text-indigo-700', light: 'text-indigo-600' },
      { border: 'border-rose-200', bg: 'from-rose-50 to-rose-100', hover: 'hover:shadow-rose-200', text: 'text-rose-900', subtext: 'text-rose-700', light: 'text-rose-600' },
      { border: 'border-amber-200', bg: 'from-amber-50 to-amber-100', hover: 'hover:shadow-amber-200', text: 'text-amber-900', subtext: 'text-amber-700', light: 'text-amber-600' },
      { border: 'border-violet-200', bg: 'from-violet-50 to-violet-100', hover: 'hover:shadow-violet-200', text: 'text-violet-900', subtext: 'text-violet-700', light: 'text-violet-600' },
      { border: 'border-lime-200', bg: 'from-lime-50 to-lime-100', hover: 'hover:shadow-lime-200', text: 'text-lime-900', subtext: 'text-lime-700', light: 'text-lime-600' }
    ];
    const color = colors[index % colors.length];
  %>
    <a href="/student/materials/<%= m.id %>" class="rounded-2xl border <%= color.border %> bg-gradient-to-br <%= color.bg %> p-5 shadow-soft hover:shadow-md <%= color.hover %> transition block">
      <div class="flex items-start justify-between gap-3">
        <div>
          <div class="text-xs <%= color.light %>"><%= m.subject_name %> • <%= m.class_name || 'Semua' %></div>
          <div class="mt-1 text-lg font-semibold <%= color.text %>"><%= m.title %></div>
        </div>
        <div>
          <% if (m.completed_at) { %>
            <span class="text-xs px-2.5 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-700 font-medium">Selesai</span>
          <% } else if (m.first_opened_at) { %>
            <span class="text-xs px-2.5 py-1 rounded-full bg-sky-500/10 border border-sky-500/20 text-sky-700 font-medium">Sudah dibaca</span>
          <% } else { %>
            <span class="text-xs px-2.5 py-1 rounded-full bg-slate-500/10 border border-slate-500/20 text-slate-700 font-medium">Belum dibaca</span>
          <% } %>
        </div>
      </div>
      <% if (m.description) { %>
        <p class="mt-3 text-sm <%= color.subtext %>"><%= m.description %></p>
      <% } %>
    </a>
  <% }) %>
</div>
