<div class="mb-6">
  <h1 class="text-3xl font-semibold tracking-tight">Tugas Saya</h1>
  <p class="mt-1 text-slate-600">Lihat dan kumpulkan tugas dari guru.</p>
</div>

<% if (assignments.length === 0) { %>
  <div class="bg-white rounded-xl shadow-soft border border-slate-200 p-12 text-center">
    <div class="text-6xl mb-4">📋</div>
    <h3 class="text-xl font-semibold text-slate-700 mb-2">Belum Ada Tugas</h3>
    <p class="text-slate-500">Saat ini tidak ada tugas yang tersedia untuk Anda.</p>
  </div>
<% } else { %>
  <div class="grid gap-4">
    <% assignments.forEach(assignment => { 
      const now = new Date();
      const dueDate = assignment.due_date ? new Date(assignment.due_date) : null;
      const isOverdue = dueDate && dueDate < now;
      const isSubmitted = assignment.submission_id !== null;
      const isGraded = isSubmitted && assignment.score !== null;
    %>
      <div class="bg-white rounded-xl shadow-soft border-2 <%= isOverdue && !isSubmitted ? 'border-red-300' : isSubmitted ? 'border-green-300' : 'border-slate-200' %> p-6 hover:shadow-lg transition-all">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-2">
              <h3 class="text-xl font-semibold text-slate-900"><%= assignment.title %></h3>
              
              <% if (isGraded) { %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-gradient-to-r from-green-500 to-emerald-600 text-white shadow-md">
                  Dinilai: <%= assignment.score %>/<%= assignment.max_score %>
                </span>
              <% } else if (isSubmitted) { %>
                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                  Sudah Dikumpulkan
                </span>
              <% } else if (isOverdue) { %>
                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">
                  Terlambat
                </span>
              <% } else { %>
                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-orange-100 text-orange-800">
                  Belum Dikumpulkan
                </span>
              <% } %>
            </div>
            
            <% if (assignment.description) { %>
              <p class="text-slate-600 mb-3"><%= assignment.description.substring(0, 150) %><%= assignment.description.length > 150 ? '...' : '' %></p>
            <% } %>
            
            <div class="flex flex-wrap gap-4 text-sm text-slate-600">
              <div class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
                <span><%= assignment.subject_name %></span>
              </div>
              <div class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                <span><%= assignment.teacher_name %></span>
              </div>
              <% if (dueDate) { %>
                <div class="flex items-center gap-1 <%= isOverdue ? 'text-red-600 font-semibold' : '' %>">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <span>Deadline: <%= dueDate.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
                </div>
              <% } else { %>
                <div class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <span>Tidak ada deadline</span>
                </div>
              <% } %>
              <div class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                </svg>
                <span>Nilai Maks: <%= assignment.max_score %></span>
              </div>
            </div>
            
            <% if (isSubmitted && assignment.submitted_at) { %>
              <div class="mt-3 pt-3 border-t border-slate-200 text-sm text-slate-600">
                <div class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span>Dikumpulkan: <%= new Date(assignment.submitted_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
                </div>
              </div>
            <% } %>
          </div>
          
          <div>
            <a 
              href="/student/assignments/<%= assignment.id %>" 
              class="inline-block px-6 py-2 <%= isSubmitted ? 'bg-blue-600 hover:bg-blue-700' : 'bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700' %> text-white font-semibold rounded-lg shadow-lg transition-all"
            >
              <%= isSubmitted ? 'Lihat Detail' : 'Kumpulkan' %>
            </a>
          </div>
        </div>
      </div>
    <% }); %>
  </div>
<% } %>
