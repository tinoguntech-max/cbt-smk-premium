<div class="flex items-end justify-between gap-4">
  <div>
    <h1 class="text-3xl font-semibold tracking-tight">Daftar Ujian</h1>
    <p class="mt-1 text-slate-600">Ujian yang tersedia untuk kelas Anda.</p>
  </div>
</div>

<div class="mt-4 flex flex-wrap gap-2">
  <a href="/student/materials" class="px-4 py-2 rounded-xl border border-teal-200 bg-gradient-to-br from-teal-50 to-teal-100 hover:from-teal-100 hover:to-teal-200 text-teal-800 font-medium transition-all">Materi</a>
  <a href="/student/assignments" class="px-4 py-2 rounded-xl border border-green-200 bg-gradient-to-br from-green-50 to-green-100 hover:from-green-100 hover:to-green-200 text-green-800 font-medium transition-all">Tugas</a>
  <a href="/student/live-classes" class="px-4 py-2 rounded-xl border border-red-200 bg-gradient-to-br from-red-50 to-red-100 hover:from-red-100 hover:to-red-200 text-red-800 font-medium transition-all">🎥 Live Classes</a>
  <a href="/student/history" class="px-4 py-2 rounded-xl border border-purple-200 bg-gradient-to-br from-purple-50 to-purple-100 hover:from-purple-100 hover:to-purple-200 text-purple-800 font-medium transition-all">Riwayat Ujian</a>
  <a href="/student/material-history" class="px-4 py-2 rounded-xl border border-cyan-200 bg-gradient-to-br from-cyan-50 to-cyan-100 hover:from-cyan-100 hover:to-cyan-200 text-cyan-800 font-medium transition-all">Riwayat Materi</a>
</div>

<div class="mt-6 grid md:grid-cols-2 xl:grid-cols-3 gap-4">
  <% if (!exams.length) { %>
    <div class="rounded-2xl border border-indigo-200 bg-gradient-to-br from-indigo-50 to-indigo-100 p-8 text-center shadow-soft">
      <div class="text-4xl mb-2">📚</div>
      <div class="text-indigo-900 font-semibold">Belum ada ujian yang dipublish.</div>
      <div class="mt-1 text-sm text-indigo-600">Cek kembali nanti ya!</div>
    </div>
  <% } %>
  <% exams.forEach((ex, index) => { 
    const colors = [
      { border: 'border-blue-200', bg: 'from-blue-50 to-blue-100', hover: 'hover:from-blue-100 hover:to-blue-200', text: 'text-blue-900', subtext: 'text-blue-700', light: 'text-blue-600' },
      { border: 'border-purple-200', bg: 'from-purple-50 to-purple-100', hover: 'hover:from-purple-100 hover:to-purple-200', text: 'text-purple-900', subtext: 'text-purple-700', light: 'text-purple-600' },
      { border: 'border-green-200', bg: 'from-green-50 to-green-100', hover: 'hover:from-green-100 hover:to-green-200', text: 'text-green-900', subtext: 'text-green-700', light: 'text-green-600' },
      { border: 'border-orange-200', bg: 'from-orange-50 to-orange-100', hover: 'hover:from-orange-100 hover:to-orange-200', text: 'text-orange-900', subtext: 'text-orange-700', light: 'text-orange-600' },
      { border: 'border-pink-200', bg: 'from-pink-50 to-pink-100', hover: 'hover:from-pink-100 hover:to-pink-200', text: 'text-pink-900', subtext: 'text-pink-700', light: 'text-pink-600' },
      { border: 'border-cyan-200', bg: 'from-cyan-50 to-cyan-100', hover: 'hover:from-cyan-100 hover:to-cyan-200', text: 'text-cyan-900', subtext: 'text-cyan-700', light: 'text-cyan-600' }
    ];
    const color = colors[index % colors.length];
  %>
    <a href="/student/exams/<%= ex.id %>" class="rounded-2xl border <%= color.border %> bg-gradient-to-br <%= color.bg %> <%= color.hover %> shadow-soft p-5 transition-all">
      <div class="flex items-center justify-between">
        <div class="text-sm <%= color.light %>"><%= ex.subject_name %></div>
        <div class="text-xs <%= color.light %> flex items-center gap-1">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          <%= ex.teacher_name %>
        </div>
      </div>
      <div class="mt-1 text-xl font-semibold <%= color.text %>"><%= ex.title %></div>
      <div class="mt-2 text-sm <%= color.subtext %> line-clamp-2"><%= ex.description || '—' %></div>
      <div class="mt-4 flex items-center justify-between text-sm <%= color.subtext %>">
        <div><span class="<%= color.light %>">Soal</span> <%= ex.question_count %></div>
        <div><span class="<%= color.light %>">Durasi</span> <%= ex.duration_minutes %> mnt</div>
      </div>
      <div class="mt-3 text-xs <%= color.light %>">Attempt: <%= ex.attempts_count %>/<%= ex.max_attempts %><% if (ex.access_code) { %> • Butuh kode akses<% } %></div>
    </a>
  <% }) %>
</div>
