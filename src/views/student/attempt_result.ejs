<div class="flex items-center justify-between gap-4">
  <div>
    <div class="text-sm text-purple-600 font-medium">📊 Hasil Ujian</div>
    <h1 class="text-3xl font-bold tracking-tight bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent"><%= attempt.title %></h1>
    <p class="mt-1 text-slate-600 flex items-center gap-2">
      <span>📚</span>
      <span><%= attempt.subject_name %></span>
    </p>
  </div>
  <a href="/student/exams" class="px-5 py-2.5 rounded-xl border-2 border-purple-200 bg-gradient-to-br from-purple-50 to-pink-100 hover:from-purple-100 hover:to-pink-200 text-purple-800 font-semibold transition-all shadow-sm hover:shadow-md">
    ← Ke Daftar Ujian
  </a>
</div>

<% if (attempt.show_score_to_student) { %>
  <% const passed = attempt.score >= attempt.pass_score; %>
  <% const percentage = Math.round((attempt.score / attempt.total_points) * 100); %>

  <!-- Celebration Banner -->
  <% if (passed) { %>
    <div class="mt-6 rounded-2xl border-2 border-green-200 bg-gradient-to-br from-green-50 via-emerald-50 to-green-100 p-6 shadow-lg animate-pulse">
      <div class="text-center">
        <div class="text-6xl mb-3">🎉</div>
        <h2 class="text-3xl font-bold text-green-900 mb-2">Selamat! Kamu LULUS!</h2>
        <p class="text-green-700 text-lg">Pertahankan prestasi yang luar biasa ini! 🌟</p>
      </div>
    </div>
  <% } else { %>
    <div class="mt-6 rounded-2xl border-2 border-orange-200 bg-gradient-to-br from-orange-50 via-amber-50 to-orange-100 p-6 shadow-lg">
      <div class="text-center">
        <div class="text-6xl mb-3">💪</div>
        <h2 class="text-3xl font-bold text-orange-900 mb-2">Jangan Menyerah!</h2>
        <p class="text-orange-700 text-lg">Belajar lagi dan coba sekali lagi. Kamu pasti bisa! 🚀</p>
      </div>
    </div>
  <% } %>

  <div class="mt-6 grid lg:grid-cols-3 gap-4">
    <!-- Card Nilai -->
    <div class="rounded-2xl border-2 <%= passed ? 'border-green-200 bg-gradient-to-br from-green-50 to-emerald-100' : 'border-orange-200 bg-gradient-to-br from-orange-50 to-amber-100' %> p-6 shadow-lg transform hover:scale-105 transition-transform">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-2xl"><%= passed ? '🏆' : '📈' %></span>
        <div class="text-sm font-semibold <%= passed ? 'text-green-700' : 'text-orange-700' %>">Nilai Kamu</div>
      </div>
      <div class="text-6xl font-bold <%= passed ? 'text-green-900' : 'text-orange-900' %> tabular-nums"><%= attempt.score %></div>
      <div class="mt-3 flex items-center justify-between">
        <div class="text-sm <%= passed ? 'text-green-700' : 'text-orange-700' %>">
          <span class="font-medium">Passing:</span> 
          <span class="font-bold text-lg"><%= attempt.pass_score %></span>
        </div>
        <div class="px-3 py-1 rounded-full <%= passed ? 'bg-green-200 text-green-900' : 'bg-orange-200 text-orange-900' %> text-xs font-bold">
          <%= percentage %>%
        </div>
      </div>
    </div>

    <!-- Card Ringkasan -->
    <div class="rounded-2xl border-2 border-blue-200 bg-gradient-to-br from-blue-50 to-cyan-100 p-6 shadow-lg">
      <div class="flex items-center gap-2 mb-4">
        <span class="text-2xl">📊</span>
        <div class="text-sm font-semibold text-blue-700">Ringkasan</div>
      </div>
      <div class="space-y-3">
        <div class="flex items-center justify-between p-3 rounded-xl bg-white/60">
          <span class="text-blue-700 font-medium flex items-center gap-2">
            <span>✅</span>
            <span>Benar</span>
          </span>
          <span class="text-blue-900 font-bold text-xl"><%= attempt.correct_count %></span>
        </div>
        <div class="flex items-center justify-between p-3 rounded-xl bg-white/60">
          <span class="text-blue-700 font-medium flex items-center gap-2">
            <span>❌</span>
            <span>Salah</span>
          </span>
          <span class="text-blue-900 font-bold text-xl"><%= attempt.wrong_count %></span>
        </div>
        <div class="flex items-center justify-between p-3 rounded-xl bg-white/60">
          <span class="text-blue-700 font-medium flex items-center gap-2">
            <span>⭐</span>
            <span>Total Poin</span>
          </span>
          <span class="text-blue-900 font-bold text-xl"><%= attempt.total_points %></span>
        </div>
      </div>
    </div>

    <!-- Card Status -->
    <div class="rounded-2xl border-2 border-purple-200 bg-gradient-to-br from-purple-50 to-pink-100 p-6 shadow-lg">
      <div class="flex items-center gap-2 mb-4">
        <span class="text-2xl">🎯</span>
        <div class="text-sm font-semibold text-purple-700">Status & Info</div>
      </div>
      
      <div class="mb-4">
        <div class="inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-bold border-2 <%= passed ? 'border-green-500 bg-gradient-to-r from-green-500 to-emerald-600 text-white shadow-lg' : 'border-orange-500 bg-gradient-to-r from-orange-500 to-red-600 text-white shadow-lg' %>">
          <span class="text-lg"><%= passed ? '✓' : '○' %></span>
          <span><%= passed ? 'LULUS' : 'BELUM LULUS' %></span>
        </div>
      </div>
      
      <div class="space-y-2 text-sm">
        <div class="p-3 rounded-xl bg-white/60">
          <div class="text-purple-600 font-medium mb-1">🕐 Waktu Selesai</div>
          <div class="text-purple-900 font-semibold">
            <%= attempt.finished_at ? new Date(attempt.finished_at).toLocaleString('id-ID', { 
              day: 'numeric', 
              month: 'short', 
              year: 'numeric',
              hour: '2-digit', 
              minute: '2-digit' 
            }) : '-' %>
          </div>
        </div>
        
        <% if (attempt.duration_minutes) { %>
          <div class="p-3 rounded-xl bg-white/60">
            <div class="text-purple-600 font-medium mb-1">⏱️ Durasi Ujian</div>
            <div class="text-purple-900 font-semibold"><%= attempt.duration_minutes %> menit</div>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Progress Bar -->
  <div class="mt-6 rounded-2xl border-2 border-indigo-200 bg-gradient-to-br from-indigo-50 to-blue-100 p-5 shadow-lg">
    <div class="flex items-center justify-between mb-3">
      <span class="text-sm font-semibold text-indigo-900">📈 Progress Jawaban Benar</span>
      <span class="text-sm font-bold text-indigo-900"><%= attempt.correct_count %>/<%= attempt.correct_count + attempt.wrong_count %> soal</span>
    </div>
    <div class="w-full bg-white/60 rounded-full h-4 overflow-hidden shadow-inner">
      <div class="h-full rounded-full bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 transition-all duration-1000 ease-out shadow-lg" style="width: <%= Math.round((attempt.correct_count / (attempt.correct_count + attempt.wrong_count)) * 100) %>%"></div>
    </div>
  </div>

<% } else { %>
  <!-- Nilai disembunyikan -->
  <div class="mt-6 rounded-2xl border-2 border-slate-200 bg-gradient-to-br from-slate-50 to-slate-100 p-8 shadow-lg text-center">
    <div class="text-6xl mb-4">📋</div>
    <h2 class="text-2xl font-bold text-slate-900 mb-3">Ujian Telah Selesai</h2>
    <p class="text-slate-600 text-lg mb-4">Terima kasih telah mengerjakan ujian dengan baik!</p>
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-100 text-blue-800 font-semibold">
      <span>✅</span>
      <span>Jawaban telah tersimpan</span>
    </div>
    <div class="mt-4 p-4 bg-amber-50 rounded-xl border border-amber-200">
      <p class="text-sm text-amber-700">
        <strong>📝 Catatan:</strong> Nilai ujian ini tidak ditampilkan kepada siswa. 
        Silakan hubungi guru untuk mengetahui hasil ujian.
      </p>
    </div>
  </div>
<% } %>

<% if (attempt.show_review_to_student && review.length > 0) { %>
  <div class="mt-6 rounded-2xl border-2 border-slate-200 bg-gradient-to-br from-slate-50 to-slate-100 p-6 shadow-lg">
    <div class="flex items-center gap-2 mb-5">
      <span class="text-3xl">📝</span>
      <h2 class="text-2xl font-bold text-slate-900">Review Jawaban</h2>
    </div>
    
    <div class="space-y-4">
      <% review.forEach((r, idx) => { %>
        <div class="rounded-2xl border-2 <%= r.is_correct ? 'border-green-200 bg-gradient-to-br from-green-50 to-emerald-50' : 'border-red-200 bg-gradient-to-br from-red-50 to-rose-50' %> p-5 shadow-md hover:shadow-lg transition-shadow">
          <div class="flex items-start justify-between mb-3">
            <div class="flex items-center gap-2">
              <span class="text-2xl"><%= r.is_correct ? '✅' : '❌' %></span>
              <span class="text-sm font-bold <%= r.is_correct ? 'text-green-700' : 'text-red-700' %>">
                Soal <%= idx+1 %>
              </span>
            </div>
            <div class="flex items-center gap-2">
              <span class="px-3 py-1 rounded-full text-xs font-bold <%= r.is_correct ? 'bg-green-200 text-green-900' : 'bg-red-200 text-red-900' %>">
                <%= r.points %> poin
              </span>
              <span class="px-3 py-1 rounded-full text-xs font-bold border-2 <%= r.is_correct ? 'border-green-500 bg-green-500 text-white' : 'border-red-500 bg-red-500 text-white' %>">
                <%= r.is_correct ? 'BENAR' : 'SALAH' %>
              </span>
            </div>
          </div>
          
          <div class="mb-3 p-4 rounded-xl bg-white/70 border border-slate-200">
            <div class="text-slate-900 font-medium whitespace-pre-line"><%= r.question_text %></div>
          </div>
          
          <% if (r.question_image) { %>
            <div class="mb-3">
              <img src="<%= r.question_image %>" alt="Gambar soal" class="max-w-full rounded-xl border-2 border-slate-200 shadow-md" loading="lazy" />
            </div>
          <% } %>
          
          <div class="grid md:grid-cols-2 gap-3">
            <div class="p-4 rounded-xl <%= r.is_correct ? 'bg-green-100/70 border-2 border-green-300' : 'bg-red-100/70 border-2 border-red-300' %>">
              <div class="text-xs font-semibold <%= r.is_correct ? 'text-green-700' : 'text-red-700' %> mb-2">
                <%= r.is_correct ? '✓ Jawaban Kamu (Benar)' : '✗ Jawaban Kamu (Salah)' %>
              </div>
              <div class="<%= r.is_correct ? 'text-green-900' : 'text-red-900' %> font-bold">
                <%= r.chosen_text || '— (Tidak dijawab)' %>
              </div>
            </div>
            
            <div class="p-4 rounded-xl bg-blue-100/70 border-2 border-blue-300">
              <div class="text-xs font-semibold text-blue-700 mb-2">🔑 Kunci Jawaban</div>
              <div class="text-blue-900 font-bold"><%= r.correct_text || '—' %></div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
<% } else if (!attempt.show_review_to_student) { %>
  <div class="mt-6 rounded-2xl border-2 border-amber-200 bg-gradient-to-br from-amber-50 to-yellow-100 p-6 shadow-lg text-center">
    <div class="text-4xl mb-3">🔒</div>
    <h3 class="text-xl font-bold text-amber-900 mb-2">Pembahasan Tidak Tersedia</h3>
    <p class="text-amber-700">
      Guru tidak mengizinkan siswa untuk melihat pembahasan dan jawaban yang benar untuk ujian ini.
    </p>
  </div>
<% } %>

<!-- Back to Top Button -->
<div class="mt-6 text-center">
  <a href="/student/exams" class="inline-block px-8 py-4 rounded-xl bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white font-bold shadow-lg hover:shadow-xl transition-all transform hover:scale-105">
    🏠 Kembali ke Daftar Ujian
  </a>
</div>
