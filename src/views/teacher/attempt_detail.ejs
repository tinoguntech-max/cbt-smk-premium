<div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4">
  <div>
    <div class="text-sm text-slate-500">Detail Nilai</div>
    <h1 class="text-3xl font-semibold tracking-tight"><%= exam.title %></h1>
    <p class="mt-1 text-slate-600"><span class="text-slate-900 font-medium"><%= student.full_name %></span> • <%= student.username %><% if (student.class_name) { %> • <%= student.class_name %><% } %></p>
  </div>
  <div class="flex gap-2">
    <a href="/teacher/grades" class="px-4 py-2 rounded-xl border border-slate-200 hover:bg-slate-100">Kembali</a>
    <a href="/teacher/exams/<%= exam.id %>" class="px-4 py-2 rounded-xl border border-slate-200 hover:bg-slate-100">Ke Ujian</a>
  </div>
</div>

<div class="mt-6 grid lg:grid-cols-3 gap-4">
  <div class="rounded-2xl border border-slate-200 bg-slate-100 p-5">
    <div class="text-sm text-slate-500">Ringkasan</div>
    <div class="mt-3 space-y-1 text-sm text-slate-600">
      <div>Status: <span class="text-slate-900 font-medium"><%= attempt.status %></span></div>
      <div>Nilai: <span class="text-slate-900 font-medium"><%= attempt.score %></span></div>
      <div>Total Poin: <span class="text-slate-900 font-medium"><%= attempt.total_points %></span></div>
      <div>Benar: <span class="text-slate-900 font-medium"><%= attempt.correct_count %></span></div>
      <div>Salah: <span class="text-slate-900 font-medium"><%= attempt.wrong_count %></span></div>
      <div>Passing: <span class="text-slate-900 font-medium"><%= exam.pass_score %></span></div>
      <div>Pelanggaran: <span class="text-slate-900 font-medium"><%= (violations || []).length %></span></div>
    </div>
    <div class="mt-4">
      <% if (attempt.status === 'SUBMITTED') { %>
        <div class="inline-flex items-center gap-2 px-3 py-2 rounded-xl <%= attempt.score >= exam.pass_score ? 'bg-emerald-500/15 border border-emerald-500/30 text-emerald-100' : 'bg-rose-500/15 border border-rose-500/30 text-rose-100' %>">
          <span class="h-2 w-2 rounded-full <%= attempt.score >= exam.pass_score ? 'bg-emerald-400' : 'bg-rose-400' %>"></span>
          <span class="text-sm font-semibold"><%= attempt.score >= exam.pass_score ? 'LULUS' : 'TIDAK LULUS' %></span>
        </div>
      <% } else { %>
        <div class="text-sm text-slate-500">Attempt belum disubmit / belum selesai.</div>
      <% } %>
    </div>

    <% if (violations && violations.length) { %>
      <div class="mt-5">
        <div class="text-sm font-semibold">Log Anti-Kecurangan</div>
        <div class="mt-2 max-h-56 overflow-auto rounded-xl border border-slate-200 bg-white">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-xs text-slate-500 border-b border-slate-200">
                <th class="px-3 py-2">Waktu</th>
                <th class="px-3 py-2">Jenis</th>
                <th class="px-3 py-2">Detail</th>
              </tr>
            </thead>
            <tbody>
              <% violations.forEach(v => { %>
                <tr class="border-b border-slate-100">
                  <td class="px-3 py-2 whitespace-nowrap text-slate-600"><%= new Date(v.created_at).toLocaleString('id-ID') %></td>
                  <td class="px-3 py-2 text-slate-900 font-medium"><%= v.violation_type %></td>
                  <td class="px-3 py-2 text-slate-600"><%= v.details || '-' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <div class="mt-2 text-xs text-slate-500">Catatan: ini pencegahan dasar berbasis browser (tidak 100% bisa mencegah semua kecurangan).</div>
      </div>
    <% } %>
  </div>

  <div class="lg:col-span-2 rounded-2xl border border-slate-200 bg-slate-100 p-5">
    <div class="flex items-center justify-between">
      <h2 class="text-xl font-semibold">Review Jawaban</h2>
      <div class="text-sm text-slate-500"><%= answers.length %> soal</div>
    </div>

    <div class="mt-4 space-y-4">
      <% answers.forEach((a, idx) => { %>
        <div class="rounded-xl border border-slate-200 bg-white p-4">
          <div class="flex items-start justify-between gap-3">
            <div>
              <div class="text-xs text-slate-500">Soal <%= idx+1 %> • <%= a.points %> poin</div>
              <div class="mt-1 text-slate-900"><%= a.question_text %></div>
              <% if (a.question_image) { %>
                <img src="<%= a.question_image %>" alt="gambar_soal" class="mt-3 max-h-64 rounded-xl border border-slate-200" />
              <% } %>
            </div>
            <div class="text-xs px-2 py-1 rounded-lg <%= a.is_correct ? 'bg-emerald-500/15 border border-emerald-500/30 text-emerald-100' : 'bg-rose-500/15 border border-rose-500/30 text-rose-100' %>">
              <%= a.is_correct ? 'BENAR' : 'SALAH' %>
            </div>
          </div>

          <div class="mt-3 grid sm:grid-cols-2 gap-2">
            <% a.options.forEach(opt => { %>
              <div class="rounded-xl border border-slate-200 px-3 py-2 text-sm
                <%= opt.id === a.correct_option_id ? 'bg-emerald-500/10 border-emerald-500/30' : '' %>
                <%= opt.id === a.chosen_option_id && opt.id !== a.correct_option_id ? 'bg-rose-500/10 border-rose-500/30' : '' %>
                <%= opt.id === a.chosen_option_id ? 'ring-1 ring-indigo-500/60' : '' %>
              ">
                <div class="flex items-start gap-2">
                  <div class="font-mono text-xs text-slate-500"><%= opt.option_label %></div>
                  <div class="text-slate-900"><%= opt.option_text %></div>
                </div>
                <div class="mt-1 text-xs text-slate-500">
                  <% if (opt.id === a.correct_option_id) { %>Kunci<% } %>
                  <% if (opt.id === a.chosen_option_id) { %><%= opt.id === a.correct_option_id ? ' • ' : '' %>Dipilih siswa<% } %>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</div>
