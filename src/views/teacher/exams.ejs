<!-- Header Section -->
<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl sm:text-3xl font-bold text-indigo-900">Kelola Ujian</h1>
    <p class="text-sm text-slate-600 mt-1">Buat ujian baru dan kelola soal dengan mudah</p>
  </div>
  <div class="flex gap-2 w-full sm:w-auto">
    <a href="/teacher" class="flex-1 sm:flex-none text-center text-sm px-4 py-2 rounded-xl border border-rose-200 bg-gradient-to-br from-rose-50 to-pink-100 hover:from-rose-100 hover:to-pink-200 text-rose-800 font-medium transition-all">
      Kembali
    </a>
    <a href="/teacher/exams/new" class="flex-1 sm:flex-none text-center text-sm px-4 py-2 rounded-xl border border-indigo-200 bg-gradient-to-br from-indigo-50 to-indigo-100 hover:from-indigo-100 hover:to-indigo-200 text-indigo-800 font-medium transition-all">
      Buat Ujian
    </a>
  </div>
</div>

<!-- Stats Summary - Responsive -->
<div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
  <div class="rounded-lg bg-blue-50 border border-blue-200 p-3 sm:p-4">
    <p class="text-xs text-blue-600 font-medium mb-1">Total Ujian</p>
    <p class="text-xl sm:text-2xl font-bold text-blue-900"><%= exams.length %></p>
  </div>
  
  <div class="rounded-lg bg-emerald-50 border border-emerald-200 p-3 sm:p-4">
    <p class="text-xs text-emerald-600 font-medium mb-1">Published</p>
    <p class="text-xl sm:text-2xl font-bold text-emerald-900"><%= exams.filter(e => e.is_published).length %></p>
  </div>
  
  <div class="rounded-lg bg-amber-50 border border-amber-200 p-3 sm:p-4">
    <p class="text-xs text-amber-600 font-medium mb-1">Draft</p>
    <p class="text-xl sm:text-2xl font-bold text-amber-900"><%= exams.filter(e => !e.is_published).length %></p>
  </div>
  
  <div class="rounded-lg bg-purple-50 border border-purple-200 p-3 sm:p-4">
    <p class="text-xs text-purple-600 font-medium mb-1">Total Soal</p>
    <p class="text-xl sm:text-2xl font-bold text-purple-900"><%= exams.reduce((sum, e) => sum + e.question_count, 0) %></p>
  </div>
</div>

<!-- Empty State -->
<% if (!exams.length) { %>
  <div class="rounded-2xl border-2 border-dashed border-slate-300 bg-slate-50 p-8 sm:p-12 text-center">
    <h3 class="text-lg sm:text-xl font-bold text-slate-700 mb-2">Belum Ada Ujian</h3>
    <p class="text-sm sm:text-base text-slate-500 mb-4">Mulai buat ujian pertama Anda untuk siswa</p>
    <a href="/teacher/exams/new" class="inline-flex items-center gap-2 px-5 py-2 rounded-lg bg-gradient-to-r from-indigo-500 to-purple-500 hover:from-indigo-600 hover:to-purple-600 text-white font-semibold shadow-md hover:shadow-lg transition-all">
      <span>+</span>
      <span>Buat Ujian Pertama</span>
    </a>
  </div>
<% } else { %>

<!-- Mobile Cards (Hidden on Desktop) -->
<div class="lg:hidden space-y-4">
  <% exams.forEach((e, index) => { 
    // Parse class names and limit to 3
    const classNames = e.class_names ? e.class_names.split(', ') : [];
    const displayClasses = classNames.slice(0, 3);
    const remainingCount = classNames.length - 3;
  %>
    <div class="rounded-xl border border-slate-200 bg-white shadow-sm overflow-hidden">
      <!-- Card Header -->
      <div class="bg-gradient-to-r from-indigo-50 to-purple-50 border-b border-slate-200 p-4">
        <div class="flex items-start justify-between gap-3 mb-2">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="inline-flex items-center px-2 py-0.5 rounded-md bg-slate-100 text-slate-700 text-xs font-mono font-semibold">
                #<%= e.id %>
              </span>
              <% if (e.is_published) { %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 text-xs font-semibold">
                  Published
                </span>
              <% } else { %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-slate-100 text-slate-600 text-xs font-semibold">
                  Draft
                </span>
              <% } %>
            </div>
            <h3 class="text-base font-bold text-slate-900 line-clamp-2"><%= e.title %></h3>
          </div>
        </div>
        
        <!-- Quick Info -->
        <div class="grid grid-cols-3 gap-2 text-xs">
          <div class="text-center p-2 rounded-lg bg-white">
            <div class="text-slate-500 mb-1">Soal</div>
            <div class="font-bold text-slate-900"><%= e.question_count %></div>
          </div>
          <div class="text-center p-2 rounded-lg bg-white">
            <div class="text-slate-500 mb-1">Durasi</div>
            <div class="font-bold text-slate-900"><%= e.duration_minutes %>'</div>
          </div>
          <div class="text-center p-2 rounded-lg bg-white">
            <div class="text-slate-500 mb-1">Kode</div>
            <div class="font-bold text-slate-900"><%= e.access_code || '—' %></div>
          </div>
        </div>
      </div>
      
      <!-- Card Body (Collapsible) -->
      <div class="p-4 space-y-3">
        <div>
          <div class="text-xs text-slate-500 mb-1">Mata Pelajaran</div>
          <div class="text-sm font-medium text-slate-900"><%= e.subject_name %></div>
        </div>
        
        <div>
          <div class="text-xs text-slate-500 mb-1">Kelas</div>
          <div class="text-sm font-medium text-slate-900">
            <% if (classNames.length === 0) { %>
              Semua Kelas
            <% } else if (classNames.length <= 3) { %>
              <%= e.class_names %>
            <% } else { %>
              <%= displayClasses.join(', ') %>
              <button 
                type="button" 
                onclick="alert('Semua Kelas:\\n<%= classNames.join('\\n') %>')"
                class="ml-1 inline-flex items-center px-2 py-0.5 rounded-md bg-indigo-100 text-indigo-700 text-xs font-semibold hover:bg-indigo-200 transition-colors"
              >
                +<%= remainingCount %> lainnya
              </button>
            <% } %>
          </div>
        </div>
        
        <!-- Action Buttons -->
        <div class="pt-3 border-t border-slate-200 flex gap-2">
          <a href="/teacher/exams/<%= e.id %>" class="flex-1 text-center px-3 py-2 rounded-lg border border-slate-300 hover:bg-slate-50 text-slate-700 text-sm font-medium transition-all">
            Detail
          </a>
          
          <a href="/teacher/exams/<%= e.id %>/edit" class="flex-1 text-center px-3 py-2 rounded-lg border border-amber-300 hover:bg-amber-50 text-amber-700 text-sm font-medium transition-all">
            Edit
          </a>
          
          <form action="/teacher/exams/<%= e.id %>/toggle-publish" method="POST" class="flex-1">
            <button type="submit" class="w-full px-3 py-2 rounded-lg <%= e.is_published ? 'bg-slate-500 hover:bg-slate-600' : 'bg-emerald-500 hover:bg-emerald-600' %> text-white text-sm font-semibold transition-all">
              <%= e.is_published ? 'Unpublish' : 'Publish' %>
            </button>
          </form>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<!-- Desktop Table (Hidden on Mobile) -->
<div class="hidden lg:block rounded-xl border border-slate-200 bg-white shadow-sm overflow-hidden">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">ID</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Judul Ujian</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Mapel</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Kelas</th>
          <th class="px-4 py-3 text-center text-xs font-semibold text-slate-600 uppercase tracking-wider">Soal</th>
          <th class="px-4 py-3 text-center text-xs font-semibold text-slate-600 uppercase tracking-wider">Durasi</th>
          <th class="px-4 py-3 text-center text-xs font-semibold text-slate-600 uppercase tracking-wider">Kode</th>
          <th class="px-4 py-3 text-center text-xs font-semibold text-slate-600 uppercase tracking-wider">Status</th>
          <th class="px-4 py-3 text-right text-xs font-semibold text-slate-600 uppercase tracking-wider">Aksi</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-slate-100">
        <% exams.forEach((e, index) => { 
          // Parse class names and limit to 3
          const classNames = e.class_names ? e.class_names.split(', ') : [];
          const displayClasses = classNames.slice(0, 3);
          const remainingCount = classNames.length - 3;
        %>
          <tr class="hover:bg-slate-50 transition-colors">
            <!-- ID -->
            <td class="px-4 py-3 whitespace-nowrap">
              <span class="inline-flex items-center px-2 py-1 rounded-md bg-slate-100 text-slate-700 text-xs font-mono font-semibold">
                #<%= e.id %>
              </span>
            </td>
            
            <!-- Judul -->
            <td class="px-4 py-3">
              <p class="text-sm font-semibold text-slate-900 truncate"><%= e.title %></p>
            </td>
            
            <!-- Mapel -->
            <td class="px-4 py-3 whitespace-nowrap">
              <span class="text-sm text-slate-700"><%= e.subject_name %></span>
            </td>
            
            <!-- Kelas -->
            <td class="px-4 py-3">
              <% if (classNames.length === 0) { %>
                <span class="text-sm text-slate-700">Semua Kelas</span>
              <% } else if (classNames.length <= 3) { %>
                <span class="text-sm text-slate-700"><%= e.class_names %></span>
              <% } else { %>
                <span class="text-sm text-slate-700"><%= displayClasses.join(', ') %></span>
                <button 
                  type="button" 
                  onclick="alert('Semua Kelas:\\n<%= classNames.join('\\n') %>')"
                  class="ml-1 inline-flex items-center px-2 py-0.5 rounded-md bg-indigo-100 text-indigo-700 text-xs font-semibold hover:bg-indigo-200 transition-colors"
                  title="<%= e.class_names %>"
                >
                  +<%= remainingCount %>
                </button>
              <% } %>
            </td>
            
            <!-- Soal -->
            <td class="px-4 py-3 text-center whitespace-nowrap">
              <span class="inline-flex items-center px-2 py-1 rounded-md <%= e.question_count > 0 ? 'bg-blue-100 text-blue-700' : 'bg-slate-100 text-slate-500' %> text-xs font-semibold">
                <%= e.question_count %>
              </span>
            </td>
            
            <!-- Durasi -->
            <td class="px-4 py-3 text-center whitespace-nowrap">
              <span class="text-xs text-slate-600"><%= e.duration_minutes %> menit</span>
            </td>
            
            <!-- Kode -->
            <td class="px-4 py-3 text-center whitespace-nowrap">
              <% if (e.access_code) { %>
                <span class="inline-flex items-center px-2 py-1 rounded-md bg-amber-100 text-amber-700 text-xs font-mono font-bold">
                  <%= e.access_code %>
                </span>
              <% } else { %>
                <span class="text-xs text-slate-400">—</span>
              <% } %>
            </td>
            
            <!-- Status -->
            <td class="px-4 py-3 text-center whitespace-nowrap">
              <% if (e.is_published) { %>
                <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-emerald-100 text-emerald-700 text-xs font-semibold">
                  Published
                </span>
              <% } else { %>
                <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-slate-100 text-slate-600 text-xs font-semibold">
                  Draft
                </span>
              <% } %>
            </td>
            
            <!-- Aksi -->
            <td class="px-4 py-3 text-right whitespace-nowrap">
              <div class="flex items-center justify-end gap-2">
                <a href="/teacher/exams/<%= e.id %>" class="inline-flex items-center px-3 py-1.5 rounded-lg border border-slate-300 hover:bg-slate-50 text-slate-700 text-xs font-medium transition-all" title="Lihat Detail">
                  Detail
                </a>
                
                <a href="/teacher/exams/<%= e.id %>/edit" class="inline-flex items-center px-3 py-1.5 rounded-lg border border-amber-300 hover:bg-amber-50 text-amber-700 text-xs font-medium transition-all" title="Edit Ujian">
                  Edit
                </a>
                
                <form action="/teacher/exams/<%= e.id %>/toggle-publish" method="POST" class="inline">
                  <button type="submit" class="inline-flex items-center px-3 py-1.5 rounded-lg <%= e.is_published ? 'bg-slate-500 hover:bg-slate-600' : 'bg-emerald-500 hover:bg-emerald-600' %> text-white text-xs font-semibold transition-all" title="<%= e.is_published ? 'Unpublish' : 'Publish' %>">
                    <%= e.is_published ? 'Unpublish' : 'Publish' %>
                  </button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<% } %>
