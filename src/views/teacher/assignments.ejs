<!-- Header -->
<div class="relative overflow-hidden rounded-2xl bg-gradient-to-r from-indigo-600 via-purple-600 to-pink-600 shadow-xl mb-6">
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-0 right-0 w-64 h-64 bg-white rounded-full -mr-32 -mt-32"></div>
    <div class="absolute bottom-0 left-0 w-48 h-48 bg-white rounded-full -ml-24 -mb-24"></div>
  </div>
  <div class="relative px-6 py-8">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-4">
        <div class="bg-white/20 backdrop-blur-sm rounded-2xl p-4">
          <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <div>
          <h1 class="text-3xl font-bold text-white tracking-tight">Kelola Tugas</h1>
          <p class="mt-1 text-indigo-100">Buat tugas baru dan kelola pengumpulan siswa</p>
        </div>
      </div>
      <div class="flex gap-2">
        <a href="/teacher" class="px-4 py-2 rounded-xl bg-white/20 backdrop-blur-sm hover:bg-white/30 text-white font-medium transition-all">
          Kembali
        </a>
        <a href="/teacher/assignments/new" class="px-4 py-2 rounded-xl bg-white text-indigo-600 hover:bg-indigo-50 font-semibold transition-all shadow-lg">
          Buat Tugas
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Stats Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <!-- Total Tugas Card -->
  <div class="relative overflow-hidden rounded-2xl shadow-lg transform hover:scale-105 transition-all duration-300">
    <div class="absolute inset-0 bg-gradient-to-br from-purple-500 via-purple-600 to-indigo-700"></div>
    <div class="absolute inset-0 opacity-20">
      <div class="absolute top-0 right-0 w-32 h-32 bg-white rounded-full -mr-16 -mt-16"></div>
      <div class="absolute bottom-0 left-0 w-24 h-24 bg-white rounded-full -ml-12 -mb-12"></div>
    </div>
    <div class="relative p-6">
      <div class="flex items-center justify-between mb-3">
        <div class="text-purple-100 text-sm font-medium uppercase tracking-wide">Total Tugas</div>
        <svg class="w-8 h-8 text-purple-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
      </div>
      <div class="text-4xl font-bold text-white mb-1"><%= assignments.length %></div>
      <div class="text-purple-200 text-xs">Tugas di sistem</div>
    </div>
  </div>

  <!-- Published Card -->
  <div class="relative overflow-hidden rounded-2xl shadow-lg transform hover:scale-105 transition-all duration-300">
    <div class="absolute inset-0 bg-gradient-to-br from-emerald-500 via-green-600 to-teal-700"></div>
    <div class="absolute inset-0 opacity-20">
      <div class="absolute top-0 right-0 w-32 h-32 bg-white rounded-full -mr-16 -mt-16"></div>
      <div class="absolute bottom-0 left-0 w-24 h-24 bg-white rounded-full -ml-12 -mb-12"></div>
    </div>
    <div class="relative p-6">
      <div class="flex items-center justify-between mb-3">
        <div class="text-green-100 text-sm font-medium uppercase tracking-wide">Published</div>
        <svg class="w-8 h-8 text-green-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div class="text-4xl font-bold text-white mb-1">
        <%= assignments.filter(a => a.is_published).length %>
      </div>
      <div class="text-green-200 text-xs">Tugas aktif</div>
    </div>
  </div>

  <!-- Draft Card -->
  <div class="relative overflow-hidden rounded-2xl shadow-lg transform hover:scale-105 transition-all duration-300">
    <div class="absolute inset-0 bg-gradient-to-br from-orange-500 via-amber-600 to-yellow-600"></div>
    <div class="absolute inset-0 opacity-20">
      <div class="absolute top-0 right-0 w-32 h-32 bg-white rounded-full -mr-16 -mt-16"></div>
      <div class="absolute bottom-0 left-0 w-24 h-24 bg-white rounded-full -ml-12 -mb-12"></div>
    </div>
    <div class="relative p-6">
      <div class="flex items-center justify-between mb-3">
        <div class="text-orange-100 text-sm font-medium uppercase tracking-wide">Draft</div>
        <svg class="w-8 h-8 text-orange-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
      </div>
      <div class="text-4xl font-bold text-white mb-1">
        <%= assignments.filter(a => !a.is_published).length %>
      </div>
      <div class="text-orange-200 text-xs">Belum dipublikasi</div>
    </div>
  </div>

  <!-- Total Submissions Card -->
  <div class="relative overflow-hidden rounded-2xl shadow-lg transform hover:scale-105 transition-all duration-300">
    <div class="absolute inset-0 bg-gradient-to-br from-blue-500 via-cyan-600 to-sky-700"></div>
    <div class="absolute inset-0 opacity-20">
      <div class="absolute top-0 right-0 w-32 h-32 bg-white rounded-full -mr-16 -mt-16"></div>
      <div class="absolute bottom-0 left-0 w-24 h-24 bg-white rounded-full -ml-12 -mb-12"></div>
    </div>
    <div class="relative p-6">
      <div class="flex items-center justify-between mb-3">
        <div class="text-blue-100 text-sm font-medium uppercase tracking-wide">Submissions</div>
        <svg class="w-8 h-8 text-blue-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
      </div>
      <div class="text-4xl font-bold text-white mb-1">
        <%= assignments.reduce((sum, a) => sum + (parseInt(a.submission_count) || 0), 0) %>
      </div>
      <div class="text-blue-200 text-xs">Total pengumpulan</div>
    </div>
  </div>
</div>

<!-- Assignments Table -->
<div class="bg-white rounded-2xl shadow-xl border-2 border-slate-100 overflow-hidden">
  <div class="bg-gradient-to-r from-slate-50 to-slate-100 px-6 py-4 border-b-2 border-slate-200">
    <div class="flex items-center gap-3">
      <div class="bg-gradient-to-r from-indigo-500 to-purple-500 rounded-lg p-2">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
        </svg>
      </div>
      <h2 class="text-lg font-bold text-slate-800">Daftar Tugas</h2>
    </div>
  </div>
  
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead class="bg-gradient-to-r from-indigo-50 to-purple-50 border-b-2 border-indigo-100">
        <tr>
          <th class="px-4 py-4 text-left text-xs font-bold text-indigo-900 uppercase tracking-wider">Tugas</th>
          <th class="px-4 py-4 text-left text-xs font-bold text-purple-900 uppercase tracking-wider">Mapel</th>
          <th class="px-4 py-4 text-left text-xs font-bold text-pink-900 uppercase tracking-wider">Kelas</th>
          <th class="px-4 py-4 text-left text-xs font-bold text-cyan-900 uppercase tracking-wider">Deadline</th>
          <th class="px-4 py-4 text-left text-xs font-bold text-blue-900 uppercase tracking-wider">Submissions</th>
          <th class="px-4 py-4 text-left text-xs font-bold text-orange-900 uppercase tracking-wider">Status</th>
          <th class="px-4 py-4 text-left text-xs font-bold text-red-900 uppercase tracking-wider">Aksi</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% if (assignments.length === 0) { %>
          <tr>
            <td colspan="7" class="px-4 py-12 text-center">
              <div class="flex flex-col items-center gap-3">
                <div class="bg-gradient-to-r from-slate-100 to-slate-200 rounded-full p-4">
                  <svg class="w-12 h-12 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                </div>
                <p class="text-slate-500 font-medium">Belum ada tugas</p>
                <p class="text-slate-400 text-sm">Mulai buat tugas pertama untuk siswa</p>
                <a href="/teacher/assignments/new" class="mt-2 px-6 py-2 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white font-semibold rounded-xl shadow-lg transform hover:scale-105 transition-all">
                  Buat Tugas
                </a>
              </div>
            </td>
          </tr>
        <% } else { %>
          <% assignments.forEach((assignment, index) => { %>
            <tr class="hover:bg-gradient-to-r hover:from-indigo-50 hover:to-purple-50 transition-all duration-200 <%= index % 2 === 0 ? 'bg-white' : 'bg-slate-50' %>">
              <td class="px-4 py-4">
                <div class="font-semibold text-slate-900"><%= assignment.title %></div>
                <% if (assignment.description) { %>
                  <div class="text-sm text-slate-600 mt-1 line-clamp-2">
                    <%= assignment.description.substring(0, 80) %><%= assignment.description.length > 80 ? '...' : '' %>
                  </div>
                <% } %>
                <div class="flex items-center gap-2 mt-2">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-slate-200 text-slate-700">
                    <%= new Date(assignment.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                  </span>
                </div>
              </td>
              <td class="px-4 py-4">
                <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-semibold bg-gradient-to-r from-purple-100 to-purple-200 text-purple-800 border border-purple-300">
                  <%= assignment.subject_name || '-' %>
                </span>
              </td>
              <td class="px-4 py-4">
                <% if (assignment.class_count > 1) { %>
                  <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-semibold bg-gradient-to-r from-purple-100 to-purple-200 text-purple-800 border border-purple-300">
                    <%= assignment.class_count %> Kelas
                  </span>
                  <div class="text-xs text-slate-600 mt-1"><%= assignment.class_names %></div>
                <% } else { %>
                  <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-semibold bg-gradient-to-r from-cyan-100 to-cyan-200 text-cyan-800 border border-cyan-300">
                    <%= assignment.class_names || 'Semua' %>
                  </span>
                <% } %>
              </td>
              <td class="px-4 py-4">
                <% if (assignment.due_date) { %>
                  <div class="text-sm font-medium text-slate-700">
                    <%= new Date(assignment.due_date).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                  </div>
                  <div class="text-xs text-slate-500">
                    <%= new Date(assignment.due_date).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %>
                  </div>
                <% } else { %>
                  <span class="text-slate-400">—</span>
                <% } %>
              </td>
              <td class="px-4 py-4">
                <div class="flex flex-col items-start gap-2">
                  <div class="flex items-center gap-2">
                    <span class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-bold bg-gradient-to-r from-blue-500 to-blue-600 text-white shadow-md">
                      <%= assignment.submission_count || 0 %> / <%= assignment.total_students || 0 %>
                    </span>
                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-bold <%= assignment.submission_percentage >= 75 ? 'bg-green-100 text-green-800' : assignment.submission_percentage >= 50 ? 'bg-yellow-100 text-yellow-800' : 'bg-red-100 text-red-800' %>">
                      <%= assignment.submission_percentage %>%
                    </span>
                  </div>
                  <div class="w-full bg-slate-200 rounded-full h-2 overflow-hidden">
                    <div class="h-2 rounded-full transition-all duration-300 <%= assignment.submission_percentage >= 75 ? 'bg-gradient-to-r from-green-500 to-emerald-600' : assignment.submission_percentage >= 50 ? 'bg-gradient-to-r from-yellow-500 to-amber-600' : 'bg-gradient-to-r from-red-500 to-rose-600' %>" style="width: <%= assignment.submission_percentage %>%"></div>
                  </div>
                </div>
              </td>
              <td class="px-4 py-4">
                <% if (assignment.is_published) { %>
                  <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-bold bg-gradient-to-r from-green-500 to-emerald-600 text-white shadow-lg">
                    Published
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-bold bg-gradient-to-r from-orange-500 to-amber-600 text-white shadow-lg">
                    Draft
                  </span>
                <% } %>
              </td>
              <td class="px-4 py-4">
                <div class="flex items-center gap-2">
                  <a 
                    href="/teacher/assignments/<%= assignment.id %>"
                    class="px-3 py-1.5 bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white text-xs font-semibold rounded-lg shadow-md transform hover:scale-105 transition-all"
                    title="Lihat Detail"
                  >
                    Detail
                  </a>
                  <a 
                    href="/teacher/assignments/<%= assignment.id %>/edit"
                    class="px-3 py-1.5 bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-600 hover:to-amber-700 text-white text-xs font-semibold rounded-lg shadow-md transform hover:scale-105 transition-all"
                    title="Edit"
                  >
                    Edit
                  </a>
                  <form method="POST" action="/teacher/assignments/<%= assignment.id %>/toggle-publish" class="inline">
                    <% if (assignment.is_published) { %>
                      <button 
                        type="submit"
                        class="px-3 py-1.5 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white text-xs font-semibold rounded-lg shadow-md transform hover:scale-105 transition-all"
                        title="Unpublish"
                      >
                        Unpublish
                      </button>
                    <% } else { %>
                      <button 
                        type="submit"
                        class="px-3 py-1.5 bg-gradient-to-r from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 text-white text-xs font-semibold rounded-lg shadow-md transform hover:scale-105 transition-all"
                        title="Publish"
                      >
                        Publish
                      </button>
                    <% } %>
                  </form>
                </div>
              </td>
            </tr>
          <% }); %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
