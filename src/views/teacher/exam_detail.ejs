<!-- Header Section -->
<div class="flex items-center justify-between gap-4 mb-6">
  <div class="flex-1">
    <div class="flex items-center gap-3 mb-2">
      <a href="/teacher/exams" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl border border-rose-200 bg-gradient-to-br from-rose-50 to-pink-100 hover:from-rose-100 hover:to-pink-200 text-rose-800 font-medium transition-all">
        ← Kembali
      </a>
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full <%= exam.is_published ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-600' %> text-xs font-semibold">
        <%= exam.is_published ? '✓ Published' : '○ Draft' %>
      </div>
    </div>
    <h1 class="text-3xl font-bold text-indigo-900"><%= exam.title %></h1>
    <div class="mt-2 flex flex-wrap items-center gap-3 text-sm text-slate-600">
      <span class="inline-flex items-center gap-1">
        <span class="w-2 h-2 rounded-full bg-indigo-400"></span>
        <%= exam.subject_name %>
      </span>
      <% if (exam.class_name) { %>
        <span class="inline-flex items-center gap-1">
          <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
          <%= exam.class_name %>
        </span>
      <% } else { %>
        <span class="inline-flex items-center gap-1">
          <span class="w-2 h-2 rounded-full bg-slate-400"></span>
          Semua Kelas
        </span>
      <% } %>
    </div>
    <% if (exam.description) { %>
      <p class="mt-3 text-slate-600"><%= exam.description %></p>
    <% } %>
  </div>
</div>

<!-- Info Cards -->
<div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-6">
  <div class="rounded-xl bg-gradient-to-br from-blue-50 to-blue-100 border border-blue-200 p-4">
    <div class="text-xs text-blue-600 font-medium mb-1">Durasi</div>
    <div class="text-2xl font-bold text-blue-900"><%= exam.duration_minutes %> <span class="text-sm font-normal">menit</span></div>
  </div>
  
  <div class="rounded-xl bg-gradient-to-br from-purple-50 to-purple-100 border border-purple-200 p-4">
    <div class="text-xs text-purple-600 font-medium mb-1">Passing Score</div>
    <div class="text-2xl font-bold text-purple-900"><%= exam.pass_score %></div>
  </div>
  
  <div class="rounded-xl bg-gradient-to-br from-amber-50 to-amber-100 border border-amber-200 p-4">
    <div class="text-xs text-amber-600 font-medium mb-1">Maks Attempt</div>
    <div class="text-2xl font-bold text-amber-900"><%= exam.max_attempts %>x</div>
  </div>
  
  <div class="rounded-xl bg-gradient-to-br from-emerald-50 to-emerald-100 border border-emerald-200 p-4">
    <div class="text-xs text-emerald-600 font-medium mb-1">Shuffle Soal</div>
    <div class="text-2xl font-bold text-emerald-900"><%= exam.shuffle_questions ? '✓' : '✗' %></div>
  </div>
  
  <div class="rounded-xl bg-gradient-to-br from-rose-50 to-rose-100 border border-rose-200 p-4">
    <div class="text-xs text-rose-600 font-medium mb-1">Shuffle Opsi</div>
    <div class="text-2xl font-bold text-rose-900"><%= exam.shuffle_options ? '✓' : '✗' %></div>
  </div>
</div>

<!-- Action Cards -->
<div class="grid md:grid-cols-2 gap-4 mb-6">
  <!-- Keamanan Card -->
  <div class="rounded-2xl border border-purple-200 bg-gradient-to-br from-purple-50 to-purple-100 p-5 shadow-soft">
    <div class="flex items-center gap-2 mb-3">
      <span class="text-2xl">🔒</span>
      <h2 class="text-lg font-semibold text-purple-900">Keamanan</h2>
    </div>
    <div class="flex items-center justify-between p-3 bg-white rounded-xl mb-3">
      <div class="text-sm text-purple-700 font-medium">Kode Akses</div>
      <div class="font-mono text-purple-900 font-bold text-lg"><%= exam.access_code ? exam.access_code : '-' %></div>
    </div>
    <form action="/teacher/exams/<%= exam.id %>/regenerate-code" method="POST">
      <button class="w-full px-4 py-2.5 rounded-xl border border-blue-200 bg-gradient-to-br from-blue-50 to-blue-100 hover:from-blue-100 hover:to-blue-200 text-blue-800 font-medium text-sm transition-all">
        🔄 Generate Kode Baru
      </button>
    </form>
  </div>

  <!-- Quick Actions Card -->
  <div class="rounded-2xl border border-indigo-200 bg-gradient-to-br from-indigo-50 to-indigo-100 p-5 shadow-soft">
    <div class="flex items-center gap-2 mb-3">
      <span class="text-2xl">⚡</span>
      <h2 class="text-lg font-semibold text-indigo-900">Aksi Cepat</h2>
    </div>
    <div class="grid grid-cols-2 gap-2">
      <button type="button" onclick="openBankSoalModal()" class="px-3 py-2.5 rounded-xl border border-indigo-200 bg-gradient-to-br from-indigo-50 to-indigo-100 hover:from-indigo-100 hover:to-indigo-200 text-indigo-800 font-medium text-sm transition-all text-center">
        📚 Bank Soal
      </button>
      <a href="/teacher/exams/<%= exam.id %>/import" class="px-3 py-2.5 rounded-xl border border-teal-200 bg-gradient-to-br from-teal-50 to-teal-100 hover:from-teal-100 hover:to-teal-200 text-teal-800 font-medium text-sm transition-all text-center">
        📥 Import Soal
      </a>
      <a href="/teacher/grades?exam_id=<%= exam.id %>" class="px-3 py-2.5 rounded-xl border border-amber-200 bg-gradient-to-br from-amber-50 to-amber-100 hover:from-amber-100 hover:to-amber-200 text-amber-800 font-medium text-sm transition-all text-center">
        📊 Daftar Nilai
      </a>
      <a href="/teacher/exams/<%= exam.id %>/export" class="px-3 py-2.5 rounded-xl border border-green-200 bg-gradient-to-br from-green-50 to-green-100 hover:from-green-100 hover:to-green-200 text-green-800 font-medium text-sm transition-all text-center">
        📥 Export Soal
      </a>
      <a href="/teacher/exams/<%= exam.id %>/edit" class="px-3 py-2.5 rounded-xl border border-purple-200 bg-gradient-to-br from-purple-50 to-purple-100 hover:from-purple-100 hover:to-purple-200 text-purple-800 font-medium text-sm transition-all text-center">
        ✏️ Edit Ujian
      </a>
      <form action="/teacher/exams/<%= exam.id %>/reset-results" method="POST" onsubmit="return confirm('Reset akan menghapus SEMUA hasil ujian (nilai & jawaban) untuk ujian ini. Lanjutkan?')" class="contents col-span-2">
        <button class="px-3 py-2.5 rounded-xl border border-rose-200 bg-gradient-to-br from-rose-50 to-rose-100 hover:from-rose-100 hover:to-rose-200 text-rose-800 font-medium text-sm transition-all">
          🗑️ Reset Hasil
        </button>
      </form>
    </div>
    <form action="/teacher/exams/<%= exam.id %>/toggle-publish" method="POST" class="mt-2">
      <button class="w-full px-4 py-2.5 rounded-xl <%= exam.is_published ? 'border border-orange-200 bg-gradient-to-br from-orange-50 to-orange-100 hover:from-orange-100 hover:to-orange-200 text-orange-800' : 'bg-gradient-to-r from-indigo-500 to-purple-600 hover:from-indigo-600 hover:to-purple-700 text-white' %> font-semibold text-sm transition-all">
        <%= exam.is_published ? '📴 Unpublish' : '📢 Publish' %>
      </button>
    </form>
  </div>
</div>

<div class="mt-8 grid lg:grid-cols-2 gap-6">
  <!-- Daftar Soal dengan Preview -->
  <div class="lg:col-span-2">
    <div class="rounded-2xl border border-cyan-200 bg-gradient-to-br from-cyan-50 to-cyan-100 p-5 shadow-soft mb-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span class="text-2xl">📝</span>
          <h2 class="text-xl font-semibold text-cyan-900">Daftar Soal</h2>
        </div>
        <div class="px-4 py-2 rounded-full bg-cyan-600 text-white text-sm font-semibold"><%= questions.length %> soal</div>
      </div>
    </div>

    <% if (!questions.length) { %>
      <div class="text-center py-12 rounded-2xl border-2 border-dashed border-cyan-300 bg-cyan-50">
        <div class="text-6xl mb-3">📝</div>
        <div class="font-semibold text-cyan-900 text-lg">Belum ada soal</div>
        <div class="text-sm text-cyan-700 mt-1">Tambahkan soal dari form di bawah</div>
      </div>
    <% } else { %>
      <div class="space-y-6">
        <% questions.forEach((q, idx) => { 
          const colors = [
            { border: 'border-blue-200', bg: 'from-blue-50 to-cyan-50', text: 'text-blue-900', badge: 'bg-blue-100 text-blue-700', btnBorder: 'border-blue-300', btnBg: 'from-blue-50 to-blue-100', btnHover: 'hover:from-blue-100 hover:to-blue-200', btnText: 'text-blue-800' },
            { border: 'border-purple-200', bg: 'from-purple-50 to-pink-50', text: 'text-purple-900', badge: 'bg-purple-100 text-purple-700', btnBorder: 'border-purple-300', btnBg: 'from-purple-50 to-purple-100', btnHover: 'hover:from-purple-100 hover:to-purple-200', btnText: 'text-purple-800' },
            { border: 'border-rose-200', bg: 'from-rose-50 to-pink-50', text: 'text-rose-900', badge: 'bg-rose-100 text-rose-700', btnBorder: 'border-rose-300', btnBg: 'from-rose-50 to-rose-100', btnHover: 'hover:from-rose-100 hover:to-rose-200', btnText: 'text-rose-800' },
            { border: 'border-emerald-200', bg: 'from-emerald-50 to-teal-50', text: 'text-emerald-900', badge: 'bg-emerald-100 text-emerald-700', btnBorder: 'border-emerald-300', btnBg: 'from-emerald-50 to-emerald-100', btnHover: 'hover:from-emerald-100 hover:to-emerald-200', btnText: 'text-emerald-800' },
            { border: 'border-amber-200', bg: 'from-amber-50 to-orange-50', text: 'text-amber-900', badge: 'bg-amber-100 text-amber-700', btnBorder: 'border-amber-300', btnBg: 'from-amber-50 to-amber-100', btnHover: 'hover:from-amber-100 hover:to-amber-200', btnText: 'text-amber-800' },
            { border: 'border-indigo-200', bg: 'from-indigo-50 to-purple-50', text: 'text-indigo-900', badge: 'bg-indigo-100 text-indigo-700', btnBorder: 'border-indigo-300', btnBg: 'from-indigo-50 to-indigo-100', btnHover: 'hover:from-indigo-100 hover:to-indigo-200', btnText: 'text-indigo-800' }
          ];
          const color = colors[idx % colors.length];
        %>
          <div class="rounded-2xl border-2 <%= color.border %> bg-gradient-to-br <%= color.bg %> p-6 shadow-lg">
            <!-- Header Soal -->
            <div class="flex items-start justify-between gap-4 mb-4">
              <div class="flex items-center gap-3">
                <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-white shadow-md">
                  <span class="text-xl font-bold <%= color.text %>"><%= idx + 1 %></span>
                </div>
                <div>
                  <div class="text-xs font-semibold <%= color.text %> opacity-75">Soal <%= idx + 1 %> dari <%= questions.length %></div>
                  <div class="inline-flex items-center gap-1 px-3 py-1 rounded-full <%= color.badge %> text-xs font-bold mt-1">
                    ⭐ <%= q.points %> poin
                  </div>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <a href="/teacher/questions/<%= q.id %>/edit" class="px-3 py-2 rounded-xl border <%= color.btnBorder %> bg-gradient-to-br <%= color.btnBg %> <%= color.btnHover %> <%= color.btnText %> font-medium text-xs transition-all">
                  ✏️ Edit
                </a>
                <form action="/teacher/questions/<%= q.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Hapus soal ini?')" class="inline">
                  <button class="px-3 py-2 rounded-xl border border-rose-300 bg-gradient-to-br from-rose-50 to-rose-100 hover:from-rose-100 hover:to-rose-200 text-rose-800 font-medium text-xs transition-all">
                    🗑️
                  </button>
                </form>
              </div>
            </div>

            <!-- Pertanyaan -->
            <div class="bg-white rounded-xl p-5 shadow-md mb-4">
              <div class="text-slate-900 leading-relaxed prose prose-sm max-w-none"><%- q.question_text %></div>
              <% if (q.question_image) { %>
                <div class="mt-4">
                  <img src="<%= q.question_image %>" alt="Gambar soal" class="max-w-full rounded-xl border-2 <%= color.border %> shadow-md" />
                </div>
              <% } %>
              <% if (q.question_pdf) { %>
                <div class="mt-4">
                  <div class="text-xs font-semibold <%= color.text %> mb-2">📄 PDF Soal:</div>
                  <iframe src="<%= q.question_pdf %>" class="w-full h-96 rounded-xl border-2 <%= color.border %> shadow-md" frameborder="0"></iframe>
                </div>
              <% } %>
            </div>

            <!-- Opsi Jawaban -->
            <div class="space-y-3">
              <div class="text-sm font-bold <%= color.text %> mb-2">Opsi Jawaban:</div>
              <% if (q.options && q.options.length > 0) { %>
                <% q.options.forEach((opt) => { %>
                  <div class="block rounded-xl border-2 <%= opt.is_correct ? color.border + ' bg-white shadow-md' : 'border-slate-200 bg-white/80' %> px-5 py-4">
                    <div class="flex gap-4">
                      <div class="flex-shrink-0">
                        <div class="inline-flex items-center justify-center w-8 h-8 rounded-lg <%= color.badge %> font-bold text-sm <%= opt.is_correct ? 'ring-2 ring-emerald-400' : '' %>">
                          <%= opt.option_label %> <%= opt.is_correct ? '✓' : '' %>
                        </div>
                      </div>
                      <div class="flex-1 text-slate-700 prose prose-sm max-w-none">
                        <%- opt.option_text %>
                      </div>
                    </div>
                  </div>
                <% }) %>
              <% } else { %>
                <div class="text-center py-4 text-slate-500 text-sm">
                  Belum ada opsi jawaban
                </div>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- Form Tambah Soal -->

  <div class="rounded-2xl border border-indigo-200 bg-gradient-to-br from-indigo-50 to-indigo-100 p-5">
    <h2 class="text-xl font-semibold text-indigo-900">Tambah Soal (PG)</h2>
    <form action="/teacher/exams/<%= exam.id %>/questions" method="POST" enctype="multipart/form-data" class="mt-4 space-y-3" id="questionForm">
      <div>
        <label class="text-sm text-indigo-700 font-medium">Pertanyaan</label>
        <div class="mt-1 relative">
          <div id="question_editor" contenteditable="true" class="w-full min-h-[150px] rounded-xl bg-white border border-indigo-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500 overflow-auto" style="max-height: 400px;"></div>
          <div class="mt-1 text-xs text-indigo-600">Tekan Ctrl+V untuk paste gambar dari clipboard</div>
        </div>
        <input type="hidden" name="question_text" id="question_text_input" required />
      </div>

      <div>
        <label class="text-sm text-indigo-700 font-medium">Gambar Soal (opsional - upload file)</label>
        <input type="file" name="image" accept="image/*" class="mt-1 w-full rounded-xl bg-white border border-indigo-200 px-4 py-3 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-indigo-100 file:text-indigo-700 hover:file:bg-indigo-200" />
        <div class="mt-1 text-xs text-indigo-600">Mendukung JPG/PNG/WebP. Max 5MB.</div>
      </div>

      <div>
        <label class="text-sm text-indigo-700 font-medium">PDF Soal (opsional - embed PDF)</label>
        <input type="file" name="pdf" accept="application/pdf" class="mt-1 w-full rounded-xl bg-white border border-indigo-200 px-4 py-3 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-purple-100 file:text-purple-700 hover:file:bg-purple-200" />
        <div class="mt-1 text-xs text-indigo-600">Upload file PDF untuk ditampilkan di soal. Max 10MB.</div>
      </div>
      
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="text-sm text-indigo-700 font-medium">Poin</label>
          <input type="number" name="points" value="1" min="1" required class="mt-1 w-full rounded-xl bg-white border border-indigo-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
        <div>
          <label class="text-sm text-indigo-700 font-medium">Jawaban Benar</label>
          <select name="correct" required class="mt-1 w-full rounded-xl bg-white border border-indigo-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500">
            <option>A</option>
            <option>B</option>
            <option>C</option>
            <option>D</option>
            <option>E</option>
          </select>
        </div>
      </div>

      <div class="space-y-3">
        <div>
          <label class="text-sm text-indigo-700 font-medium">Opsi A</label>
          <div id="option_a_editor" contenteditable="true" class="mt-1 w-full min-h-[80px] rounded-xl bg-white border border-indigo-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500 overflow-auto" style="max-height: 300px;"></div>
          <input type="hidden" name="a" id="option_a_input" required />
        </div>
        <div>
          <label class="text-sm text-indigo-700 font-medium">Opsi B</label>
          <div id="option_b_editor" contenteditable="true" class="mt-1 w-full min-h-[80px] rounded-xl bg-white border border-indigo-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500 overflow-auto" style="max-height: 300px;"></div>
          <input type="hidden" name="b" id="option_b_input" required />
        </div>
        <div>
          <label class="text-sm text-indigo-700 font-medium">Opsi C</label>
          <div id="option_c_editor" contenteditable="true" class="mt-1 w-full min-h-[80px] rounded-xl bg-white border border-indigo-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500 overflow-auto" style="max-height: 300px;"></div>
          <input type="hidden" name="c" id="option_c_input" required />
        </div>
        <div>
          <label class="text-sm text-indigo-700 font-medium">Opsi D</label>
          <div id="option_d_editor" contenteditable="true" class="mt-1 w-full min-h-[80px] rounded-xl bg-white border border-indigo-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500 overflow-auto" style="max-height: 300px;"></div>
          <input type="hidden" name="d" id="option_d_input" required />
        </div>
        <div>
          <label class="text-sm text-indigo-700 font-medium">Opsi E</label>
          <div id="option_e_editor" contenteditable="true" class="mt-1 w-full min-h-[80px] rounded-xl bg-white border border-indigo-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500 overflow-auto" style="max-height: 300px;"></div>
          <input type="hidden" name="e" id="option_e_input" required />
        </div>
      </div>

      <button type="submit" class="w-full rounded-xl bg-gradient-to-r from-indigo-500 to-purple-600 hover:from-indigo-600 hover:to-purple-700 text-white font-semibold py-3 transition-all">Simpan Soal</button>
    </form>
  </div>
</div>

<script>
  // Setup paste image handler for all contenteditable divs
  const editors = [
    'question_editor',
    'option_a_editor',
    'option_b_editor',
    'option_c_editor',
    'option_d_editor',
    'option_e_editor'
  ];

  editors.forEach(editorId => {
    const editor = document.getElementById(editorId);
    
    // Handle paste event
    editor.addEventListener('paste', function(e) {
      e.preventDefault();
      
      const items = e.clipboardData.items;
      let hasImage = false;
      
      for (let i = 0; i < items.length; i++) {
        if (items[i].type.indexOf('image') !== -1) {
          hasImage = true;
          const blob = items[i].getAsFile();
          const reader = new FileReader();
          
          reader.onload = function(event) {
            const img = document.createElement('img');
            img.src = event.target.result;
            img.style.maxWidth = '100%';
            img.style.height = 'auto';
            img.style.margin = '10px 0';
            img.style.borderRadius = '8px';
            img.style.border = '2px solid #e0e7ff';
            
            // Insert image at cursor position
            const selection = window.getSelection();
            if (selection.rangeCount > 0) {
              const range = selection.getRangeAt(0);
              range.deleteContents();
              range.insertNode(img);
              
              // Move cursor after image
              range.setStartAfter(img);
              range.setEndAfter(img);
              selection.removeAllRanges();
              selection.addRange(range);
            } else {
              editor.appendChild(img);
            }
          };
          
          reader.readAsDataURL(blob);
        }
      }
      
      // If no image, paste text normally
      if (!hasImage) {
        const text = e.clipboardData.getData('text/plain');
        document.execCommand('insertText', false, text);
      }
    });

    // Add placeholder behavior
    const placeholder = editorId === 'question_editor' ? 'Ketik pertanyaan di sini atau paste gambar (Ctrl+V)...' : 'Ketik opsi jawaban atau paste gambar...';
    
    if (editor.textContent.trim() === '') {
      editor.setAttribute('data-placeholder', placeholder);
    }
    
    editor.addEventListener('focus', function() {
      if (this.textContent.trim() === '') {
        this.removeAttribute('data-placeholder');
      }
    });
    
    editor.addEventListener('blur', function() {
      if (this.textContent.trim() === '' && this.querySelectorAll('img').length === 0) {
        this.setAttribute('data-placeholder', placeholder);
      }
    });
  });

  // Form submit handler
  document.getElementById('questionForm').addEventListener('submit', function(e) {
    // Copy content from contenteditable to hidden inputs
    document.getElementById('question_text_input').value = document.getElementById('question_editor').innerHTML;
    document.getElementById('option_a_input').value = document.getElementById('option_a_editor').innerHTML;
    document.getElementById('option_b_input').value = document.getElementById('option_b_editor').innerHTML;
    document.getElementById('option_c_input').value = document.getElementById('option_c_editor').innerHTML;
    document.getElementById('option_d_input').value = document.getElementById('option_d_editor').innerHTML;
    document.getElementById('option_e_input').value = document.getElementById('option_e_editor').innerHTML;

    // Validate that fields are not empty
    const fields = [
      { id: 'question_editor', name: 'Pertanyaan' },
      { id: 'option_a_editor', name: 'Opsi A' },
      { id: 'option_b_editor', name: 'Opsi B' },
      { id: 'option_c_editor', name: 'Opsi C' },
      { id: 'option_d_editor', name: 'Opsi D' },
      { id: 'option_e_editor', name: 'Opsi E' }
    ];

    for (const field of fields) {
      const editor = document.getElementById(field.id);
      const text = editor.textContent.trim();
      const images = editor.querySelectorAll('img');
      
      if (text === '' && images.length === 0) {
        e.preventDefault();
        alert(`${field.name} tidak boleh kosong!`);
        editor.focus();
        return false;
      }
    }

    return true;
  });
</script>

<style>
  [contenteditable]:empty:before {
    content: attr(data-placeholder);
    color: #94a3b8;
    pointer-events: none;
  }
  
  [contenteditable] {
    outline: none;
  }
  
  [contenteditable] img {
    cursor: pointer;
    transition: transform 0.2s;
  }
  
  [contenteditable] img:hover {
    transform: scale(1.02);
  }
</style>


<!-- Modal Bank Soal -->
<div id="bankSoalModal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl shadow-2xl max-w-6xl w-full max-h-[90vh] overflow-hidden flex flex-col">
    <!-- Modal Header -->
    <div class="flex items-center justify-between p-6 border-b border-slate-200 bg-gradient-to-r from-indigo-50 to-purple-50">
      <div>
        <h2 class="text-2xl font-bold text-indigo-900">📚 Pilih Soal dari Bank</h2>
        <p class="text-sm text-slate-600 mt-1">Pilih soal yang ingin ditambahkan ke ujian ini</p>
      </div>
      <button onclick="closeBankSoalModal()" class="p-2 rounded-xl hover:bg-slate-100 transition-all">
        <svg class="w-6 h-6 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    
    <!-- Filter -->
    <div class="p-4 border-b border-slate-200 bg-slate-50">
      <div class="grid md:grid-cols-4 gap-3">
        <div>
          <label class="text-xs text-slate-600 font-medium">Mata Pelajaran</label>
          <select id="filterSubject" onchange="loadBankSoal()" class="mt-1 w-full rounded-lg bg-white border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
            <option value="">Semua</option>
          </select>
        </div>
        
        <div>
          <label class="text-xs text-slate-600 font-medium">Kesulitan</label>
          <select id="filterDifficulty" onchange="loadBankSoal()" class="mt-1 w-full rounded-lg bg-white border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
            <option value="">Semua</option>
            <option value="EASY">Mudah</option>
            <option value="MEDIUM">Sedang</option>
            <option value="HARD">Sulit</option>
          </select>
        </div>
        
        <div>
          <label class="text-xs text-slate-600 font-medium">Cari</label>
          <input type="text" id="filterSearch" onkeyup="loadBankSoal()" placeholder="Cari soal..." class="mt-1 w-full rounded-lg bg-white border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
        
        <div class="flex items-end">
          <button onclick="loadBankSoal()" class="w-full rounded-lg bg-indigo-500 hover:bg-indigo-600 text-white font-semibold py-2 text-sm">
            🔍 Filter
          </button>
        </div>
      </div>
    </div>
    
    <!-- Modal Body -->
    <div id="bankSoalList" class="flex-1 overflow-y-auto p-6">
      <div class="text-center py-12">
        <div class="text-4xl mb-3">⏳</div>
        <div class="text-slate-600">Memuat bank soal...</div>
      </div>
    </div>
    
    <!-- Modal Footer -->
    <div class="p-4 border-t border-slate-200 bg-slate-50 flex justify-between items-center">
      <div class="text-sm text-slate-600">
        <span id="selectedCount">0</span> soal dipilih
      </div>
      <div class="flex gap-2">
        <button onclick="closeBankSoalModal()" class="px-4 py-2 rounded-xl border border-slate-200 hover:bg-slate-100 text-slate-700 font-medium text-sm transition-all">
          Batal
        </button>
        <button onclick="addSelectedQuestions()" class="px-4 py-2 rounded-xl bg-gradient-to-r from-indigo-500 to-purple-600 hover:from-indigo-600 hover:to-purple-700 text-white font-semibold text-sm transition-all">
          ➕ Tambahkan Soal
        </button>
      </div>
    </div>
  </div>
</div>

<script>
let selectedQuestions = new Set();

function openBankSoalModal() {
  document.getElementById('bankSoalModal').classList.remove('hidden');
  document.body.style.overflow = 'hidden';
  loadBankSoal();
  loadSubjects();
}

function closeBankSoalModal() {
  document.getElementById('bankSoalModal').classList.add('hidden');
  document.body.style.overflow = 'auto';
  selectedQuestions.clear();
  updateSelectedCount();
}

async function loadSubjects() {
  try {
    const response = await fetch('/api/subjects');
    const subjects = await response.json();
    const select = document.getElementById('filterSubject');
    subjects.forEach(s => {
      const option = document.createElement('option');
      option.value = s.id;
      option.textContent = s.name;
      select.appendChild(option);
    });
  } catch (error) {
    console.error('Error loading subjects:', error);
  }
}

async function loadBankSoal() {
  const subjectId = document.getElementById('filterSubject').value;
  const difficulty = document.getElementById('filterDifficulty').value;
  const search = document.getElementById('filterSearch').value;
  
  const params = new URLSearchParams();
  if (subjectId) params.append('subject_id', subjectId);
  if (difficulty) params.append('difficulty', difficulty);
  if (search) params.append('search', search);
  
  const listDiv = document.getElementById('bankSoalList');
  listDiv.innerHTML = '<div class="text-center py-12"><div class="text-4xl mb-3">⏳</div><div class="text-slate-600">Memuat...</div></div>';
  
  try {
    const response = await fetch(`/api/question-bank?${params.toString()}`);
    const questions = await response.json();
    
    if (questions.length === 0) {
      listDiv.innerHTML = `
        <div class="text-center py-12">
          <div class="text-6xl mb-3">📚</div>
          <div class="font-semibold text-slate-900 text-lg">Tidak ada soal</div>
          <div class="text-sm text-slate-600 mt-1">Coba ubah filter atau tambahkan soal ke bank terlebih dahulu</div>
        </div>
      `;
      return;
    }
    
    const colors = [
      { border: 'border-blue-200', bg: 'from-blue-50 to-cyan-50', badge: 'bg-blue-100 text-blue-700' },
      { border: 'border-purple-200', bg: 'from-purple-50 to-pink-50', badge: 'bg-purple-100 text-purple-700' },
      { border: 'border-emerald-200', bg: 'from-emerald-50 to-teal-50', badge: 'bg-emerald-100 text-emerald-700' },
      { border: 'border-amber-200', bg: 'from-amber-50 to-orange-50', badge: 'bg-amber-100 text-amber-700' }
    ];
    
    const difficultyLabels = {
      'EASY': { text: 'Mudah', color: 'bg-green-100 text-green-700' },
      'MEDIUM': { text: 'Sedang', color: 'bg-yellow-100 text-yellow-700' },
      'HARD': { text: 'Sulit', color: 'bg-red-100 text-red-700' }
    };
    
    listDiv.innerHTML = questions.map((q, idx) => {
      const color = colors[idx % colors.length];
      const diff = difficultyLabels[q.difficulty] || difficultyLabels['MEDIUM'];
      const isSelected = selectedQuestions.has(q.id);
      
      return `
        <div class="mb-4 rounded-xl border-2 ${color.border} bg-gradient-to-br ${color.bg} p-4 ${isSelected ? 'ring-4 ring-indigo-400' : ''} transition-all">
          <div class="flex items-start gap-4">
            <input type="checkbox" 
                   id="q_${q.id}" 
                   ${isSelected ? 'checked' : ''}
                   onchange="toggleQuestion(${q.id})"
                   class="mt-1 w-5 h-5 rounded accent-indigo-500 cursor-pointer" />
            <label for="q_${q.id}" class="flex-1 cursor-pointer">
              <div class="flex items-center gap-2 mb-2">
                <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full ${color.badge} text-xs font-bold">
                  ${q.subject_name}
                </span>
                <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full ${diff.color} text-xs font-bold">
                  ${diff.text}
                </span>
                <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full bg-slate-100 text-slate-700 text-xs font-bold">
                  ⭐ ${q.points} poin
                </span>
              </div>
              <div class="text-slate-900 text-sm leading-relaxed line-clamp-2">
                ${q.question_text.replace(/<[^>]*>/g, '').substring(0, 200)}...
              </div>
              ${q.tags ? `
                <div class="mt-2 flex flex-wrap gap-1">
                  ${q.tags.split(',').map(tag => `<span class="px-2 py-0.5 rounded-lg bg-white/80 text-xs text-slate-600">#${tag.trim()}</span>`).join('')}
                </div>
              ` : ''}
            </label>
          </div>
        </div>
      `;
    }).join('');
    
  } catch (error) {
    console.error('Error loading bank soal:', error);
    listDiv.innerHTML = `
      <div class="text-center py-12">
        <div class="text-6xl mb-3">❌</div>
        <div class="font-semibold text-red-900 text-lg">Gagal memuat bank soal</div>
        <div class="text-sm text-red-600 mt-1">${error.message}</div>
      </div>
    `;
  }
}

function toggleQuestion(id) {
  if (selectedQuestions.has(id)) {
    selectedQuestions.delete(id);
  } else {
    selectedQuestions.add(id);
  }
  updateSelectedCount();
}

function updateSelectedCount() {
  document.getElementById('selectedCount').textContent = selectedQuestions.size;
}

async function addSelectedQuestions() {
  if (selectedQuestions.size === 0) {
    alert('Pilih minimal 1 soal');
    return;
  }
  
  const examId = <%= exam.id %>;
  const questionIds = Array.from(selectedQuestions);
  
  try {
    const response = await fetch(`/api/question-bank/add-to-exam/${examId}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ questionIds })
    });
    
    const result = await response.json();
    
    if (response.ok) {
      alert(`Berhasil menambahkan ${result.added} soal ke ujian`);
      closeBankSoalModal();
      location.reload();
    } else {
      alert('Gagal menambahkan soal: ' + result.error);
    }
  } catch (error) {
    console.error('Error adding questions:', error);
    alert('Gagal menambahkan soal: ' + error.message);
  }
}

// Close modal on ESC key
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape' && !document.getElementById('bankSoalModal').classList.contains('hidden')) {
    closeBankSoalModal();
  }
});
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
