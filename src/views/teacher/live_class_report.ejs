<div class="space-y-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
    <div class="flex-1">
      <h1 class="text-2xl sm:text-3xl font-bold text-slate-800">📊 Laporan Live Class</h1>
      <p class="text-sm sm:text-base text-slate-600 mt-1"><%= liveClass.title %></p>
    </div>
    <a href="/teacher/live-classes" class="w-full sm:w-auto text-center px-4 py-2 rounded-xl border border-slate-200 bg-white hover:bg-slate-50 text-slate-700 font-medium transition-all">
      ← Kembali
    </a>
  </div>

  <!-- Live Class Info -->
  <div class="bg-white rounded-2xl shadow-soft p-4 sm:p-6">
    <h2 class="text-lg font-semibold text-slate-800 mb-4">Informasi Live Class</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div>
        <div class="text-xs text-slate-500 mb-1">Mata Pelajaran</div>
        <div class="font-medium text-slate-800">📚 <%= liveClass.subject_name %></div>
      </div>
      <div>
        <div class="text-xs text-slate-500 mb-1">Kelas</div>
        <div class="font-medium text-slate-800">👥 <%= liveClass.class_name || 'Semua Kelas' %></div>
      </div>
      <div>
        <div class="text-xs text-slate-500 mb-1">Durasi</div>
        <div class="font-medium text-slate-800">⏱️ <%= liveClass.duration_minutes %> menit</div>
      </div>
      <div>
        <div class="text-xs text-slate-500 mb-1">Status</div>
        <div class="font-medium">
          <% if (liveClass.status === 'ENDED') { %>
            <span class="text-slate-600">✓ Selesai</span>
          <% } else if (liveClass.status === 'LIVE') { %>
            <span class="text-red-600">🔴 Sedang Berlangsung</span>
          <% } else { %>
            <span class="text-blue-600">📅 Terjadwal</span>
          <% } %>
        </div>
      </div>
    </div>

    <div class="mt-4 pt-4 border-t border-slate-200">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
        <div>
          <span class="text-slate-500">Dijadwalkan:</span>
          <span class="ml-2 font-medium text-slate-800">
            <%= new Date(liveClass.scheduled_at).toLocaleString('id-ID', { 
              weekday: 'long', 
              year: 'numeric', 
              month: 'long', 
              day: 'numeric',
              hour: '2-digit',
              minute: '2-digit'
            }) %>
          </span>
        </div>
        <% if (liveClass.started_at) { %>
          <div>
            <span class="text-slate-500">Dimulai:</span>
            <span class="ml-2 font-medium text-slate-800">
              <%= new Date(liveClass.started_at).toLocaleString('id-ID', { 
                hour: '2-digit',
                minute: '2-digit'
              }) %>
            </span>
          </div>
        <% } %>
        <% if (liveClass.ended_at) { %>
          <div>
            <span class="text-slate-500">Diakhiri:</span>
            <span class="ml-2 font-medium text-slate-800">
              <%= new Date(liveClass.ended_at).toLocaleString('id-ID', { 
                hour: '2-digit',
                minute: '2-digit'
              }) %>
            </span>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Statistics -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-2xl border-2 border-blue-200 p-4 sm:p-6 shadow-soft">
      <div class="text-blue-600 text-sm font-medium mb-2">Total Partisipasi</div>
      <div class="text-3xl sm:text-4xl font-bold text-blue-900"><%= stats.totalParticipants %></div>
      <div class="text-xs text-blue-600 mt-1">kali join</div>
    </div>

    <div class="bg-gradient-to-br from-green-50 to-green-100 rounded-2xl border-2 border-green-200 p-4 sm:p-6 shadow-soft">
      <div class="text-green-600 text-sm font-medium mb-2">Siswa Unik</div>
      <div class="text-3xl sm:text-4xl font-bold text-green-900"><%= stats.uniqueParticipants %></div>
      <div class="text-xs text-green-600 mt-1">siswa berbeda</div>
    </div>

    <div class="bg-gradient-to-br from-purple-50 to-purple-100 rounded-2xl border-2 border-purple-200 p-4 sm:p-6 shadow-soft">
      <div class="text-purple-600 text-sm font-medium mb-2">Rata-rata Durasi</div>
      <div class="text-3xl sm:text-4xl font-bold text-purple-900"><%= stats.avgDuration %></div>
      <div class="text-xs text-purple-600 mt-1">menit per siswa</div>
    </div>
  </div>

  <!-- Participants List -->
  <div class="bg-white rounded-2xl shadow-soft p-4 sm:p-6">
    <h2 class="text-lg font-semibold text-slate-800 mb-4">Daftar Partisipan (<%= participants.length %>)</h2>

    <% if (participants.length === 0) { %>
      <div class="text-center py-12">
        <div class="text-4xl mb-3">👥</div>
        <div class="text-slate-600">Belum ada siswa yang join live class ini</div>
      </div>
    <% } else { %>
      <!-- Desktop Table -->
      <div class="hidden sm:block overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-slate-200">
              <th class="text-left py-3 px-4 text-sm font-semibold text-slate-700">No</th>
              <th class="text-left py-3 px-4 text-sm font-semibold text-slate-700">Nama Siswa</th>
              <th class="text-left py-3 px-4 text-sm font-semibold text-slate-700">Username</th>
              <th class="text-left py-3 px-4 text-sm font-semibold text-slate-700">Kelas</th>
              <th class="text-left py-3 px-4 text-sm font-semibold text-slate-700">Join</th>
              <th class="text-left py-3 px-4 text-sm font-semibold text-slate-700">Leave</th>
              <th class="text-left py-3 px-4 text-sm font-semibold text-slate-700">Durasi</th>
            </tr>
          </thead>
          <tbody>
            <% participants.forEach((p, index) => { %>
              <tr class="border-b border-slate-100 hover:bg-slate-50">
                <td class="py-3 px-4 text-sm text-slate-600"><%= index + 1 %></td>
                <td class="py-3 px-4 text-sm font-medium text-slate-800"><%= p.full_name %></td>
                <td class="py-3 px-4 text-sm text-slate-600"><%= p.username %></td>
                <td class="py-3 px-4 text-sm text-slate-600"><%= p.class_name || '-' %></td>
                <td class="py-3 px-4 text-sm text-slate-600">
                  <%= new Date(p.joined_at).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %>
                </td>
                <td class="py-3 px-4 text-sm text-slate-600">
                  <% if (p.left_at) { %>
                    <%= new Date(p.left_at).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %>
                  <% } else { %>
                    <span class="text-green-600 font-medium">Masih di room</span>
                  <% } %>
                </td>
                <td class="py-3 px-4 text-sm font-medium text-slate-800"><%= p.duration_minutes %> mnt</td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Mobile Cards -->
      <div class="sm:hidden space-y-3">
        <% participants.forEach((p, index) => { %>
          <div class="border border-slate-200 rounded-xl p-4">
            <div class="flex items-start justify-between mb-3">
              <div class="flex-1">
                <div class="font-semibold text-slate-800"><%= index + 1 %>. <%= p.full_name %></div>
                <div class="text-xs text-slate-500 mt-1">@<%= p.username %> • <%= p.class_name || '-' %></div>
              </div>
              <div class="text-right">
                <div class="text-sm font-bold text-indigo-600"><%= p.duration_minutes %> mnt</div>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-2 text-xs">
              <div>
                <span class="text-slate-500">Join:</span>
                <span class="ml-1 text-slate-700">
                  <%= new Date(p.joined_at).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %>
                </span>
              </div>
              <div>
                <span class="text-slate-500">Leave:</span>
                <span class="ml-1 text-slate-700">
                  <% if (p.left_at) { %>
                    <%= new Date(p.left_at).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %>
                  <% } else { %>
                    <span class="text-green-600 font-medium">Di room</span>
                  <% } %>
                </span>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>
