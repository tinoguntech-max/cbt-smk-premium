<div class="max-w-3xl mx-auto">
  <div class="mb-6">
    <a href="/teacher/live-classes" class="text-indigo-600 hover:text-indigo-800 font-medium">← Kembali</a>
  </div>

  <div class="bg-white rounded-2xl shadow-soft p-8">
    <h1 class="text-3xl font-bold text-slate-800 mb-6">Buat Live Class</h1>

    <form action="/teacher/live-classes" method="POST" class="space-y-6">
      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-2">Judul Live Class *</label>
        <input type="text" name="title" required 
               class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
               placeholder="Contoh: Pengenalan Algoritma Pemrograman">
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-2">Deskripsi</label>
        <textarea name="description" rows="3"
                  class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                  placeholder="Deskripsi singkat tentang live class ini..."></textarea>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-2">Mata Pelajaran *</label>
          <select name="subject_id" required 
                  class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
            <option value="">Pilih Mata Pelajaran</option>
            <% subjects.forEach(subject => { %>
              <option value="<%= subject.id %>"><%= subject.name %></option>
            <% }) %>
          </select>
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-2">Kelas *</label>
          <select name="class_id" required 
                  class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
            <option value="">Pilih Kelas</option>
            <% classes.forEach(cls => { %>
              <option value="<%= cls.id %>"><%= cls.name %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-2">Jadwal *</label>
          <input type="datetime-local" name="scheduled_at" required 
                 class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-2">Durasi (menit) *</label>
          <input type="number" name="duration_minutes" value="60" min="15" max="240" required 
                 class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
        </div>
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-2">Maksimal Peserta</label>
        <input type="number" name="max_participants" value="100" min="1" max="500" 
               class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
        <p class="text-xs text-slate-500 mt-1">Kosongkan atau isi 100 untuk default</p>
      </div>

      <div class="bg-blue-50 border border-blue-200 rounded-xl p-4">
        <h3 class="font-semibold text-blue-900 mb-2">ℹ️ Informasi</h3>
        <ul class="text-sm text-blue-800 space-y-1">
          <li>• Notifikasi akan otomatis dikirim ke semua siswa di kelas yang dipilih</li>
          <li>• Live class menggunakan Jitsi Meet untuk video conference</li>
          <li>• Anda bisa membuat live quiz interaktif saat live class berlangsung</li>
          <li>• Kehadiran siswa akan otomatis tercatat</li>
        </ul>
      </div>

      <div class="flex gap-3">
        <button type="submit" 
                class="flex-1 px-6 py-3 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white font-semibold rounded-xl shadow-sm transition-all">
          Buat Live Class
        </button>
        <a href="/teacher/live-classes" 
           class="px-6 py-3 bg-slate-200 hover:bg-slate-300 text-slate-800 font-semibold rounded-xl transition-colors">
          Batal
        </a>
      </div>
    </form>
  </div>
</div>
