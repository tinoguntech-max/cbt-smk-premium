<div class="flex items-center justify-between gap-4 mb-6">
  <div>
    <h1 class="text-3xl font-bold text-indigo-900">Edit Ujian</h1>
    <p class="text-sm text-slate-600 mt-1">Perbarui informasi ujian</p>
  </div>
  <a href="/teacher/exams" class="text-sm px-4 py-2 rounded-xl border border-rose-200 bg-gradient-to-br from-rose-50 to-pink-100 hover:from-rose-100 hover:to-pink-200 text-rose-800 font-medium transition-all">
    Kembali
  </a>
</div>

<form action="/teacher/exams/<%= exam.id %>?_method=PUT" method="POST" class="space-y-4">
  
  <!-- Mata Pelajaran & Kelas -->
  <div class="rounded-2xl border border-blue-200 bg-gradient-to-br from-blue-50 to-blue-100 p-6 shadow-soft">
    <h2 class="text-lg font-semibold text-blue-900 mb-4">📚 Mata Pelajaran & Kelas</h2>
    <div class="grid md:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-blue-800 mb-2">Mata Pelajaran</label>
        <select name="subject_id" required class="w-full rounded-xl border border-blue-200 bg-white px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="">Pilih Mata Pelajaran</option>
          <% subjects.forEach(s => { %>
            <option value="<%= s.id %>" <%= exam.subject_id === s.id ? 'selected' : '' %>><%= s.name %></option>
          <% }) %>
        </select>
      </div>
      
      <div>
        <label class="block text-sm font-medium text-blue-800 mb-2">Kelas yang Dapat Mengerjakan</label>
        <div class="relative">
          <div id="classSelector" class="w-full rounded-xl border border-blue-200 bg-white px-4 py-3 cursor-pointer hover:bg-blue-50 transition-colors">
            <span id="selectedClassesText" class="text-slate-600">Pilih kelas...</span>
          </div>
          <div id="classDropdown" class="hidden absolute z-10 mt-2 w-full rounded-xl border border-blue-200 bg-white shadow-lg max-h-64 overflow-y-auto">
            <div class="p-3 border-b border-blue-100">
              <label class="flex items-center gap-2 cursor-pointer hover:bg-blue-50 p-2 rounded-lg">
                <input type="checkbox" id="selectAllClasses" class="w-4 h-4 accent-blue-500" />
                <span class="text-sm font-semibold text-blue-900">Pilih Semua</span>
              </label>
            </div>
            <div class="p-2">
              <% classes.forEach(c => { %>
                <label class="flex items-center gap-2 cursor-pointer hover:bg-blue-50 p-2 rounded-lg">
                  <input type="checkbox" name="class_ids[]" value="<%= c.id %>" class="class-checkbox w-4 h-4 accent-blue-500" <%= selectedClassIds.includes(c.id) ? 'checked' : '' %> />
                  <span class="text-sm text-slate-700"><%= c.name %></span>
                </label>
              <% }) %>
            </div>
          </div>
        </div>
        <div id="selectedClassesTags" class="mt-2 flex flex-wrap gap-2"></div>
      </div>
    </div>
  </div>

  <!-- Detail Ujian -->
  <div class="rounded-2xl border border-purple-200 bg-gradient-to-br from-purple-50 to-purple-100 p-6 shadow-soft">
    <h2 class="text-lg font-semibold text-purple-900 mb-4">📝 Detail Ujian</h2>
    <div class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-purple-800 mb-2">Judul Ujian</label>
        <input type="text" name="title" value="<%= exam.title %>" required class="w-full rounded-xl border border-purple-200 bg-white px-4 py-3 focus:outline-none focus:ring-2 focus:ring-purple-500" placeholder="Contoh: Ujian Tengah Semester Matematika" />
      </div>
      
      <div>
        <label class="block text-sm font-medium text-purple-800 mb-2">Deskripsi (opsional)</label>
        <textarea name="description" rows="3" class="w-full rounded-xl border border-purple-200 bg-white px-4 py-3 focus:outline-none focus:ring-2 focus:ring-purple-500" placeholder="Tambahkan deskripsi atau instruksi khusus..."><%= exam.description || '' %></textarea>
      </div>
    </div>
  </div>

  <!-- Jadwal -->
  <div class="rounded-2xl border border-emerald-200 bg-gradient-to-br from-emerald-50 to-emerald-100 p-6 shadow-soft">
    <h2 class="text-lg font-semibold text-emerald-900 mb-4">📅 Jadwal</h2>
    <div class="grid md:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-emerald-800 mb-2">Mulai</label>
        <input 
          type="datetime-local" 
          name="start_at" 
          id="start_at"
          value="<%= exam.start_at ? new Date(new Date(exam.start_at).getTime() - new Date(exam.start_at).getTimezoneOffset() * 60000).toISOString().slice(0,16) : '' %>" 
          required
          class="w-full rounded-xl border border-emerald-200 bg-white px-4 py-3 focus:outline-none focus:ring-2 focus:ring-emerald-500" 
        />
      </div>
      
      <div>
        <label class="block text-sm font-medium text-emerald-800 mb-2">Selesai</label>
        <input 
          type="datetime-local" 
          name="end_at" 
          id="end_at"
          value="<%= exam.end_at ? new Date(new Date(exam.end_at).getTime() - new Date(exam.end_at).getTimezoneOffset() * 60000).toISOString().slice(0,16) : '' %>" 
          required
          class="w-full rounded-xl border border-emerald-200 bg-white px-4 py-3 focus:outline-none focus:ring-2 focus:ring-emerald-500" 
        />
      </div>
    </div>
  </div>

  <!-- Pengaturan -->
  <div class="rounded-2xl border border-amber-200 bg-gradient-to-br from-amber-50 to-amber-100 p-6 shadow-soft">
    <h2 class="text-lg font-semibold text-amber-900 mb-4">⚙️ Pengaturan</h2>
    <div class="grid md:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium text-amber-800 mb-2">Durasi (menit)</label>
        <input type="number" name="duration_minutes" value="<%= exam.duration_minutes %>" min="1" required class="w-full rounded-xl border border-amber-200 bg-white px-4 py-3 focus:outline-none focus:ring-2 focus:ring-amber-500" />
      </div>
      
      <div>
        <label class="block text-sm font-medium text-amber-800 mb-2">Nilai Lulus</label>
        <input type="number" name="pass_score" value="<%= exam.pass_score %>" min="0" max="100" required class="w-full rounded-xl border border-amber-200 bg-white px-4 py-3 focus:outline-none focus:ring-2 focus:ring-amber-500" />
      </div>
      
      <div>
        <label class="block text-sm font-medium text-amber-800 mb-2">Maks Percobaan</label>
        <input type="number" name="max_attempts" value="<%= exam.max_attempts %>" min="1" required class="w-full rounded-xl border border-amber-200 bg-white px-4 py-3 focus:outline-none focus:ring-2 focus:ring-amber-500" />
      </div>
    </div>
    
    <div class="mt-4 grid md:grid-cols-2 gap-4">
      <label class="flex items-center gap-3 p-4 rounded-xl border border-amber-200 bg-white cursor-pointer hover:bg-amber-50 transition-colors">
        <input type="checkbox" name="shuffle_questions" value="1" <%= exam.shuffle_questions ? 'checked' : '' %> class="w-5 h-5 accent-amber-500" />
        <span class="text-sm font-medium text-amber-900">Acak Urutan Soal</span>
      </label>
      
      <label class="flex items-center gap-3 p-4 rounded-xl border border-amber-200 bg-white cursor-pointer hover:bg-amber-50 transition-colors">
        <input type="checkbox" name="shuffle_options" value="1" <%= exam.shuffle_options ? 'checked' : '' %> class="w-5 h-5 accent-amber-500" />
        <span class="text-sm font-medium text-amber-900">Acak Opsi Jawaban</span>
      </label>
    </div>
  </div>

  <!-- Keamanan -->
  <div class="rounded-2xl border border-rose-200 bg-gradient-to-br from-rose-50 to-rose-100 p-6 shadow-soft">
    <h2 class="text-lg font-semibold text-rose-900 mb-4">🔒 Keamanan</h2>
    <div>
      <label class="block text-sm font-medium text-rose-800 mb-2">Kode Akses (opsional)</label>
      <input type="text" name="access_code" value="<%= exam.access_code || '' %>" maxlength="10" class="w-full rounded-xl border border-rose-200 bg-white px-4 py-3 focus:outline-none focus:ring-2 focus:ring-rose-500" placeholder="Kosongkan untuk tanpa kode" />
      <p class="mt-2 text-xs text-rose-600">Siswa harus memasukkan kode ini untuk mengakses ujian</p>
    </div>
  </div>

  <!-- Submit Button -->
  <div class="flex gap-3">
    <button type="submit" class="flex-1 rounded-xl bg-gradient-to-r from-indigo-500 to-purple-600 hover:from-indigo-600 hover:to-purple-700 text-white font-semibold py-4 shadow-lg hover:shadow-xl transition-all">
      Simpan Perubahan
    </button>
    <a href="/teacher/exams" class="px-6 rounded-xl border border-slate-300 hover:bg-slate-50 text-slate-700 font-semibold py-4 transition-all">
      Batal
    </a>
  </div>
</form>

<script>
  // Class selector functionality
  const classSelector = document.getElementById('classSelector');
  const classDropdown = document.getElementById('classDropdown');
  const selectAllCheckbox = document.getElementById('selectAllClasses');
  const classCheckboxes = document.querySelectorAll('.class-checkbox');
  const selectedClassesText = document.getElementById('selectedClassesText');
  const selectedClassesTags = document.getElementById('selectedClassesTags');

  // Toggle dropdown
  classSelector.addEventListener('click', () => {
    classDropdown.classList.toggle('hidden');
  });

  // Close dropdown when clicking outside
  document.addEventListener('click', (e) => {
    if (!classSelector.contains(e.target) && !classDropdown.contains(e.target)) {
      classDropdown.classList.add('hidden');
    }
  });

  // Select all functionality
  selectAllCheckbox.addEventListener('change', () => {
    classCheckboxes.forEach(cb => {
      cb.checked = selectAllCheckbox.checked;
    });
    updateSelectedClasses();
  });

  // Individual checkbox change
  classCheckboxes.forEach(cb => {
    cb.addEventListener('change', () => {
      updateSelectedClasses();
      // Update select all checkbox
      selectAllCheckbox.checked = Array.from(classCheckboxes).every(c => c.checked);
    });
  });

  // Update selected classes display
  function updateSelectedClasses() {
    const selected = Array.from(classCheckboxes).filter(cb => cb.checked);
    const count = selected.length;
    
    if (count === 0) {
      selectedClassesText.textContent = 'Pilih kelas...';
      selectedClassesTags.innerHTML = '';
    } else {
      selectedClassesText.textContent = `${count} kelas dipilih`;
      
      // Create tags
      const colors = [
        'bg-blue-100 text-blue-700',
        'bg-purple-100 text-purple-700',
        'bg-pink-100 text-pink-700',
        'bg-emerald-100 text-emerald-700',
        'bg-amber-100 text-amber-700',
        'bg-rose-100 text-rose-700'
      ];
      
      selectedClassesTags.innerHTML = selected.map((cb, idx) => {
        const label = cb.parentElement.querySelector('span').textContent;
        const colorClass = colors[idx % colors.length];
        return `<span class="px-3 py-1 rounded-full text-xs font-semibold ${colorClass}">${label}</span>`;
      }).join('');
    }
  }

  // Initialize on page load
  updateSelectedClasses();
</script>
