<div class="max-w-3xl mx-auto space-y-6">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold text-slate-800">Edit Live Class</h1>
      <p class="text-sm text-slate-600 mt-1">Update informasi live class yang terjadwal</p>
    </div>
    <a href="/teacher/live-classes" class="px-4 py-2 rounded-xl border border-slate-200 bg-white hover:bg-slate-50 text-slate-700 font-medium transition-all">
      ← Kembali
    </a>
  </div>

  <!-- Form -->
  <form action="/teacher/live-classes/<%= liveClass.id %>/update" method="POST" class="bg-white rounded-2xl shadow-soft p-6 space-y-6">
    <!-- Subject -->
    <div>
      <label class="block text-sm font-semibold text-slate-700 mb-2">
        Mata Pelajaran <span class="text-red-500">*</span>
      </label>
      <select name="subject_id" required class="w-full rounded-xl border-2 border-slate-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all">
        <option value="">Pilih Mata Pelajaran</option>
        <% subjects.forEach(subject => { %>
          <option value="<%= subject.id %>" <%= liveClass.subject_id === subject.id ? 'selected' : '' %>>
            <%= subject.name %>
          </option>
        <% }) %>
      </select>
    </div>

    <!-- Class -->
    <div>
      <label class="block text-sm font-semibold text-slate-700 mb-2">
        Kelas <span class="text-slate-500 text-xs">(Opsional - kosongkan untuk semua kelas)</span>
      </label>
      <select name="class_id" class="w-full rounded-xl border-2 border-slate-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all">
        <option value="">Semua Kelas</option>
        <% classes.forEach(cls => { %>
          <option value="<%= cls.id %>" <%= liveClass.class_id === cls.id ? 'selected' : '' %>>
            <%= cls.name %>
          </option>
        <% }) %>
      </select>
    </div>

    <!-- Title -->
    <div>
      <label class="block text-sm font-semibold text-slate-700 mb-2">
        Judul Live Class <span class="text-red-500">*</span>
      </label>
      <input 
        type="text" 
        name="title" 
        value="<%= liveClass.title %>"
        required 
        placeholder="Contoh: Pengenalan Komputer"
        class="w-full rounded-xl border-2 border-slate-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all"
      />
    </div>

    <!-- Description -->
    <div>
      <label class="block text-sm font-semibold text-slate-700 mb-2">
        Deskripsi <span class="text-slate-500 text-xs">(Opsional)</span>
      </label>
      <textarea 
        name="description" 
        rows="3"
        placeholder="Deskripsi singkat tentang live class ini..."
        class="w-full rounded-xl border-2 border-slate-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all"
      ><%= liveClass.description || '' %></textarea>
    </div>

    <!-- Scheduled At -->
    <div>
      <label class="block text-sm font-semibold text-slate-700 mb-2">
        Jadwal <span class="text-red-500">*</span>
      </label>
      <input 
        type="datetime-local" 
        name="scheduled_at" 
        value="<%= new Date(liveClass.scheduled_at).toISOString().slice(0, 16) %>"
        required 
        class="w-full rounded-xl border-2 border-slate-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all"
      />
      <p class="text-xs text-slate-500 mt-1">Pilih tanggal dan waktu mulai live class</p>
    </div>

    <!-- Duration & Max Participants -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-2">
          Durasi (menit) <span class="text-red-500">*</span>
        </label>
        <input 
          type="number" 
          name="duration_minutes" 
          value="<%= liveClass.duration_minutes %>"
          min="15" 
          max="240" 
          required 
          placeholder="60"
          class="w-full rounded-xl border-2 border-slate-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all"
        />
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-2">
          Maks. Peserta <span class="text-red-500">*</span>
        </label>
        <input 
          type="number" 
          name="max_participants" 
          value="<%= liveClass.max_participants %>"
          min="1" 
          max="500" 
          required 
          placeholder="100"
          class="w-full rounded-xl border-2 border-slate-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all"
        />
      </div>
    </div>

    <!-- Submit Buttons -->
    <div class="flex gap-3 pt-4 border-t border-slate-200">
      <a href="/teacher/live-classes" class="flex-1 text-center px-6 py-3 rounded-xl border-2 border-slate-300 hover:bg-slate-50 text-slate-700 font-semibold transition-all">
        Batal
      </a>
      <button type="submit" class="flex-1 px-6 py-3 rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white font-semibold shadow-lg hover:shadow-xl transition-all">
        💾 Simpan Perubahan
      </button>
    </div>
  </form>
</div>
