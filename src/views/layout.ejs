<!doctype html>
<html lang="id" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <meta name="theme-color" content="#4F46E5" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <title><%= title ? title + ' • ' : '' %>LMS SMKN 1 Kras</title>
    
    <!-- PWA Manifest -->
    <link rel="manifest" href="/public/manifest.json" />
    <link rel="icon" type="image/png" href="/public/images/logo.png" />
    <link rel="apple-touch-icon" href="/public/images/logo.png" />
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            boxShadow: { soft: '0 10px 30px rgba(0,0,0,0.08)' }
          }
        }
      };
    </script>
    
    <!-- Capacitor Core (only loads in native app) -->
    <script type="module">
      if (window.Capacitor) {
        import('https://cdn.jsdelivr.net/npm/@capacitor/core@latest/dist/index.js').then(module => {
          window.Capacitor = module.Capacitor;
        });
      }
    </script>
  </head>
  <body class="h-full bg-slate-100 text-slate-900">
    <div class="min-h-full">
      <%- include('partials/navbar') %>
      
      <main class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
        <%- include('partials/flash') %>
        <%- body %>
      </main>
      <footer class="border-t border-slate-200">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6 text-sm text-slate-500 flex items-center justify-between">
          <div>LMS SMKN 1 Kras</div>
          <div class="opacity-80">Node.js • MySQL • Tailwind</div>
        </div>
      </footer>
    </div>

    <!-- Service Worker Registration -->
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/public/service-worker.js')
            .then(reg => console.log('Service Worker registered:', reg.scope))
            .catch(err => console.error('Service Worker registration failed:', err));
        });
      }
    </script>



    <!-- Capacitor Native Plugins -->
    <script src="/public/capacitor.js"></script>

    <!-- Notification Script (Only for Students) -->
    <% if (typeof user !== 'undefined' && user && user.role) { 
      const userRole = user.role.toLowerCase();
      if (userRole === 'student') { %>
    
    <!-- OLD NOTIFICATION SYSTEM - DISABLED
    <script>
      // Sistem notifikasi lama dinonaktifkan, diganti dengan modal notification system
    </script>
    -->

    <!-- Modal Notification System (Peringatan dari Guru/Admin) -->
    <script>
      (function() {
        console.log('[Notification] Script loaded for student');
        console.log('[Notification] User role:', '<%= user.role %>');
        console.log('[Notification] User ID:', '<%= user.id %>');
        
        let shownNotifications = new Set();
        const storageKey = 'closedNotifications';
        
        // Load closed notifications from localStorage
        try {
          const closed = localStorage.getItem(storageKey);
          if (closed) {
            shownNotifications = new Set(JSON.parse(closed));
            console.log('[Notification] Loaded closed notifications:', shownNotifications.size);
          }
        } catch (e) {
          console.error('[Notification] Error loading closed notifications:', e);
        }

        async function checkModalNotifications() {
          console.log('[Notification] Checking for new notifications...');
          try {
            const response = await fetch('/notifications/active');
            const data = await response.json();
            
            console.log('[Notification] Response:', data);
            
            if (data.notifications && data.notifications.length > 0) {
              console.log('[Notification] Found', data.notifications.length, 'notifications');
              // Show first unshown notification
              for (const notif of data.notifications) {
                if (!shownNotifications.has(notif.id)) {
                  console.log('[Notification] Showing notification:', notif.id);
                  showModalNotification(notif);
                  break; // Only show one at a time
                }
              }
            } else {
              console.log('[Notification] No new notifications');
            }
          } catch (error) {
            console.error('[Notification] Error checking modal notifications:', error);
          }
        }

        function showModalNotification(notif) {
          const colors = {
            info: { bg: 'from-blue-50 to-cyan-50', border: 'border-blue-300', text: 'text-blue-900', icon: 'ℹ️' },
            warning: { bg: 'from-orange-50 to-amber-50', border: 'border-orange-300', text: 'text-orange-900', icon: '⚠️' },
            success: { bg: 'from-green-50 to-emerald-50', border: 'border-green-300', text: 'text-green-900', icon: '✅' },
            error: { bg: 'from-red-50 to-rose-50', border: 'border-red-300', text: 'text-red-900', icon: '❌' }
          };
          const color = colors[notif.type] || colors.info;

          const modal = document.createElement('div');
          modal.id = 'modalNotification_' + notif.id;
          modal.className = 'fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm animate-fadeIn';
          modal.innerHTML = `
            <div class="rounded-2xl border-2 ${color.border} bg-gradient-to-br ${color.bg} p-6 shadow-2xl max-w-md mx-4 animate-scaleIn">
              <div class="flex items-start justify-between gap-4 mb-4">
                <div class="flex items-center gap-3">
                  <span class="text-4xl">${color.icon}</span>
                  <h2 class="text-xl font-bold ${color.text}">${escapeHtml(notif.title)}</h2>
                </div>
                <button onclick="closeModalNotification(${notif.id})" class="text-slate-400 hover:text-slate-600 transition-colors">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </button>
              </div>
              
              <div class="bg-white/70 rounded-xl p-4 mb-4">
                <p class="${color.text} whitespace-pre-wrap">${escapeHtml(notif.message)}</p>
              </div>
              
              <div class="flex items-center justify-between text-xs text-slate-600 mb-4">
                <span>📅 ${new Date(notif.created_at).toLocaleString('id-ID')}</span>
              </div>
              
              <button onclick="closeModalNotification(${notif.id})" class="w-full px-6 py-3 rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white font-bold shadow-lg hover:shadow-xl transition-all transform hover:scale-105">
                ✓ Mengerti
              </button>
            </div>
          `;
          
          document.body.appendChild(modal);
          shownNotifications.add(notif.id);
          saveClosedNotifications();
        }

        window.closeModalNotification = async function(notifId) {
          const modal = document.getElementById('modalNotification_' + notifId);
          if (modal) {
            modal.classList.add('animate-fadeOut');
            setTimeout(() => modal.remove(), 300);
          }
          
          // Mark as read on server
          try {
            await fetch(`/notifications/${notifId}/read`, { method: 'POST' });
          } catch (error) {
            console.error('Error marking notification as read:', error);
          }
        };

        function saveClosedNotifications() {
          try {
            localStorage.setItem(storageKey, JSON.stringify([...shownNotifications]));
          } catch (e) {
            console.error('Error saving closed notifications:', e);
          }
        }

        function escapeHtml(text) {
          const div = document.createElement('div');
          div.textContent = text;
          return div.innerHTML;
        }

        // Check on page load
        checkModalNotifications();
        
        // Check every 60 seconds
        setInterval(checkModalNotifications, 60000);
      })();
    </script>

    <style>
      @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      @keyframes fadeOut {
        from { opacity: 1; }
        to { opacity: 0; }
      }
      @keyframes scaleIn {
        from { transform: scale(0.9); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
      }
      .animate-fadeIn {
        animation: fadeIn 0.3s ease-out;
      }
      .animate-fadeOut {
        animation: fadeOut 0.3s ease-out;
      }
      .animate-scaleIn {
        animation: scaleIn 0.3s ease-out;
      }
    </style>
    <% }} %>
  </body>
</html>
